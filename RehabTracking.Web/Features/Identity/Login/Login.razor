@page "/login"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Đăng nhập - STEP</PageTitle>

<div class="login-page d-flex align-items-center justify-content-center" style="min-height: calc(100vh - 70px); background: linear-gradient(135deg, #f8fafc 0%, #e0e7ff 100%);">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">
                <!-- Logo / Brand -->
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mb-3" style="width:72px;height:72px;">
                        <i class="bi bi-activity text-primary" style="font-size:2rem;"></i>
                    </div>
                    <h2 class="fw-bold text-dark">Chào mừng trở lại</h2>
                    <p class="text-muted">Đăng nhập vào tài khoản STEP của bạn</p>
                </div>

                <div class="card border-0 shadow-lg rounded-4">
                    <div class="card-body p-4 p-md-5">
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger border-0 rounded-3 d-flex align-items-center gap-2 mb-4" role="alert">
                                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                                <span>@errorMessage</span>
                            </div>
                        }

                        @if (showSuccessMessage)
                        {
                            <div class="alert alert-success border-0 rounded-3 d-flex align-items-center gap-2 mb-4" role="alert">
                                <i class="bi bi-check-circle-fill flex-shrink-0"></i>
                                <span>Đăng ký thành công! Vui lòng đăng nhập.</span>
                            </div>
                        }

                        <form method="post" action="/api/auth/login">
                            <input type="hidden" name="ReturnUrl" value="@returnUrl" />
                            <div class="mb-3">
                                <label for="email" class="form-label fw-semibold text-dark">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                        <i class="bi bi-envelope text-muted"></i>
                                    </span>
                                    <input type="email" id="email" name="Email" class="form-control bg-light border-start-0 rounded-end-3"
                                           placeholder="email@example.com"
                                           value="@demoEmail"
                                           @oninput="e => demoEmail = e.Value?.ToString() ?? string.Empty"
                                           required />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="password" class="form-label fw-semibold text-dark mb-1">Mật khẩu</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                        <i class="bi bi-lock text-muted"></i>
                                    </span>
                                    <input type="@(showPassword ? "text" : "password")" id="password" name="Password"
                                           class="form-control bg-light border-start-0"
                                           placeholder="••••••••"
                                           value="@demoPwd"
                                           @oninput="e => demoPwd = e.Value?.ToString() ?? string.Empty"
                                           required />
                                    <button type="button" class="input-group-text bg-light border-start-0 rounded-end-3"
                                            @onclick="TogglePassword" style="cursor:pointer;" title="@(showPassword ? "Ẩn mật khẩu" : "Hiện mật khẩu")">
                                        <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye") text-muted"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="d-grid mb-3">
                                <button type="submit" class="btn btn-modern-primary btn-lg rounded-pill fw-semibold shadow-sm">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                                </button>
                            </div>
                        </form>

                        <div class="text-center">
                            <span class="text-muted">Chưa có tài khoản?</span>
                            <a href="/register" class="text-primary fw-semibold ms-1">Đăng ký ngay</a>
                        </div>
                    </div>
                </div>

                <!-- Demo accounts -->
                <div class="card border-0 shadow-sm rounded-4 mt-3">
                    <div class="card-body p-3">
                        <p class="text-muted small text-center mb-2 fw-semibold">
                            <i class="bi bi-info-circle me-1"></i>Tài khoản demo (click để điền tự động)
                        </p>
                        <div class="row g-2">
                            <div class="col-6">
                                <button class="btn btn-light btn-sm w-100 rounded-3 text-start py-2 demo-btn" @onclick='() => FillDemo("doctor@test.com", "123456")'>
                                    <i class="bi bi-person-badge text-primary me-1"></i>
                                    <span class="fw-semibold small">Bác sĩ</span><br/>
                                    <span class="text-muted" style="font-size:0.7rem;">doctor@test.com</span>
                                </button>
                            </div>
                            <div class="col-6">
                                <button class="btn btn-light btn-sm w-100 rounded-3 text-start py-2 demo-btn" @onclick='() => FillDemo("patient@test.com", "123456")'>
                                    <i class="bi bi-person-heart text-success me-1"></i>
                                    <span class="fw-semibold small">Bệnh nhân</span><br/>
                                    <span class="text-muted" style="font-size:0.7rem;">patient@test.com</span>
                                </button>
                            </div>
                            <div class="col-12">
                                <button class="btn btn-light btn-sm w-100 rounded-3 text-start py-2 demo-btn" @onclick='() => FillDemo("admin@test.com", "123456")'>
                                    <i class="bi bi-speedometer2 text-danger me-1"></i>
                                    <span class="fw-semibold small">Admin / Nhân viên kho</span>
                                    <span class="text-muted ms-1" style="font-size:0.7rem;">admin@test.com</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Override card hover lift for login card */
    .login-page .card.rounded-4:hover {
        transform: none !important;
    }
    .input-group-text {
        border-color: #dee2e6;
    }
    .input-group .form-control {
        border-color: #dee2e6;
    }
    .input-group .form-control:focus {
        border-color: #4f46e5;
        box-shadow: none;
    }
    .input-group:focus-within .input-group-text {
        border-color: #4f46e5;
    }
    .demo-btn {
        transition: all 0.15s ease;
    }
    .demo-btn:hover {
        background: rgba(79,70,229,0.06) !important;
        border-color: rgba(79,70,229,0.3) !important;
    }
</style>

@code {
    private string errorMessage = string.Empty;
    private bool showSuccessMessage = false;
    private string returnUrl = string.Empty;
    private string demoEmail = string.Empty;
    private string demoPwd = string.Empty;
    private bool showPassword = false;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("error", out var error) && error == "InvalidCredentials")
        {
            errorMessage = "Email hoặc mật khẩu không đúng. Vui lòng thử lại.";
        }
        if (query.TryGetValue("registered", out var reg) && reg == "true")
        {
            showSuccessMessage = true;
        }
        if (query.TryGetValue("returnUrl", out var rUrl))
        {
            returnUrl = rUrl!;
        }
        // Demo pre-fill from query (email only, no password in URL)
        if (query.TryGetValue("demo_email", out var dEmail))
        {
            demoEmail = dEmail!;
        }
        // Note: demo_pwd is no longer passed via URL for security reasons
    }

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    /// <summary>
    /// FillDemo: điền thông tin demo vào form bằng Blazor state,
    /// không lộ password qua URL/browser history.
    /// </summary>
    private void FillDemo(string email, string password)
    {
        demoEmail = email;
        demoPwd = password;
        // No navigation needed - Blazor state binding updates the form inputs directly
        // Email is still passed via URL for returnUrl support but password is NOT
    }
}
