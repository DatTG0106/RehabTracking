@page "/doctor-dashboard"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using MediatR
@using RehabTracking.Web.Entities
@using RehabTracking.Web.Features.Healthcare.DoctorDashboard
@using Radzen.Blazor
@attribute [Authorize(Roles = "Doctor")]
@inject IMediator Mediator
@inject NavigationManager Navigation
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Dashboard Bác sĩ - STEP</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12 d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h2 class="fw-bold text-dark mb-1" style="font-size: 2rem;">Trung tâm Theo dõi Bệnh nhân</h2>
                <p class="text-muted mb-0">Theo dõi tiến trình phục hồi trực tiếp và điều chỉnh phác đồ từ xa.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="/doctor/exercise-plans" class="btn btn-modern-primary rounded-pill px-4 py-2 shadow-sm fw-semibold">
                    <i class="bi bi-journal-medical me-2"></i>Lộ trình Bài tập
                </a>
            </div>
        </div>
    </div>

    <!-- Quick Stats Bar -->
    @if (patients != null && patients.Any())
    {
        <div class="row g-3 mb-4">
            <div class="col-sm-6 col-xl-3">
                <div class="modern-card p-3 d-flex align-items-center gap-3">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-3 d-flex justify-content-center align-items-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size:1.6rem;line-height:1;">@patients.Count</div>
                        <div class="text-muted small fw-semibold">Bệnh nhân</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="modern-card p-3 d-flex align-items-center gap-3">
                    <div class="bg-success bg-opacity-10 text-success rounded-3 d-flex justify-content-center align-items-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-calendar-check-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size:1.6rem;line-height:1;">@patients.SelectMany(p => p.ExerciseSessions ?? new List<ExerciseSession>()).Count(s => s.StartTime.Date == DateTime.UtcNow.Date)</div>
                        <div class="text-muted small fw-semibold">Buổi tập hôm nay</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="modern-card p-3 d-flex align-items-center gap-3">
                    <div class="bg-info bg-opacity-10 text-info rounded-3 d-flex justify-content-center align-items-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-clipboard2-pulse-fill fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size:1.6rem;line-height:1;">@patients.Count(p => p.TreatmentPlans?.Any() == true)</div>
                        <div class="text-muted small fw-semibold">Có phác đồ</div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-xl-3">
                <div class="modern-card p-3 d-flex align-items-center gap-3">
                    <div class="@(liveData.Any() ? "bg-success" : "bg-secondary") bg-opacity-10 @(liveData.Any() ? "text-success" : "text-secondary") rounded-3 d-flex justify-content-center align-items-center flex-shrink-0" style="width:48px;height:48px;">
                        <i class="bi bi-wifi fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark" style="font-size:1.6rem;line-height:1;">@(liveData.Any() ? "Live" : "---")</div>
                        <div class="text-muted small fw-semibold">Kết nối thiết bị</div>
                    </div>
                </div>
            </div>
        </div>
    }
    
    <div class="row g-4">
        <!-- Sidebar Patient Roster (Now as top horizontal cards on mobile/lg-left) -->
        <div class="col-xl-3 col-lg-4">
            <div class="d-flex flex-column gap-3">
                <div class="modern-card p-3">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span class="fw-bold text-muted text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.05em;">Bệnh nhân của bạn</span>
                        <span class="badge bg-primary rounded-pill">@(filteredPatients?.Count ?? 0)</span>
                    </div>
                    <input type="search" class="form-control form-control-sm rounded-3 bg-light" 
                           placeholder="🔍 Tìm bệnh nhân..." @bind="searchQuery" @bind:event="oninput"
                           style="font-size: 0.88rem;" />
                </div>

                @if (patients == null)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                }
                else if (!patients.Any())
                {
                    <div class="modern-card p-4 text-center" style="border: 2px dashed #e2e8f0;">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width:60px;height:60px;">
                            <i class="bi bi-person-plus text-primary fs-3"></i>
                        </div>
                        <p class="text-muted small mb-0">Chưa có bệnh nhân nào được phân công.</p>
                        <p class="text-muted" style="font-size:0.78rem;">Liên hệ Admin để được phân bệnh nhân.</p>
                    </div>
                }
                else
                {
                    @if (filteredPatients?.Any() == false && !string.IsNullOrEmpty(searchQuery))
                    {
                        <div class="text-center py-3 text-muted small">
                            <i class="bi bi-search me-1"></i>Không tìm thấy "@searchQuery"
                        </div>
                    }
                    <div class="patient-list d-flex flex-lg-column gap-3 overflow-auto pb-2 pb-lg-0" style="max-height: calc(100vh - 250px);">
                        @if (filteredPatients != null)
                        {
                            @foreach (var patient in filteredPatients)
                            {
                            bool isSelected = selectedPatient?.PatientId == patient.PatientId;
                            <div class="modern-card p-3 cursor-pointer @(isSelected ? "border-primary border-2" : "border-0")" 
                                 style="cursor: pointer; min-width: 250px; transition: all 0.2s; @(isSelected ? "box-shadow: 0 0 0 0.25rem rgba(79,70,229,0.25);" : "")"
                                 @onclick="() => SelectPatient(patient)">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex justify-content-center align-items-center text-primary fw-bold" style="width: 48px; height: 48px; font-size: 1.2rem;">
                                        @(patient.User?.FullName?.Substring(0, 1).ToUpper() ?? "P")
                                    </div>
                                    <div>
                                        <h6 class="fw-bold mb-0 text-dark">@patient.User?.FullName</h6>
                                        <span class="text-muted small">@patient.Gender • @(patient.DateOfBirth.HasValue ? (DateTime.Now.Year - patient.DateOfBirth.Value.Year) : 0) tuổi</span>
                                    </div>
                                </div>
                            </div>
                        }
                        }
                    </div>
                }
            </div>
        </div>
        
        <!-- Main Content Area -->
        <div class="col-xl-9 col-lg-8">
            @if (selectedPatient != null)
            {
                <div class="row g-4 mb-4">
                    <!-- Profile Summary Card -->
                    <div class="col-md-7">
                        <div class="modern-card p-4 h-100">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <h4 class="fw-bold text-dark mb-1">@selectedPatient.User?.FullName</h4>
                                    <span class="badge badge-soft-warning px-3 py-2 rounded-pill">
                                        <i class="bi bi-file-medical"></i> @selectedPatient.MedicalHistory
                                    </span>
                                </div>
                                <button class="btn btn-modern-primary rounded-pill btn-sm px-4 py-2" @onclick="ShowTreatmentModal">
                                    <i class="bi bi-sliders me-1"></i> Điều chỉnh Phác đồ
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(successMessage))
                            {
                                <div class="alert @(isSuccessAlert ? "alert-success" : "alert-danger") alert-dismissible border-0 rounded-3 d-flex align-items-center gap-2 mb-3 fade-in">
                                    <i class="bi @(isSuccessAlert ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") flex-shrink-0"></i>
                                    <span>@successMessage</span>
                                    <button type="button" class="btn-close" @onclick="() => successMessage = string.Empty"></button>
                                </div>
                            }
                            
                            <hr class="text-muted opacity-25">
                            
                            <div class="row mt-4">
                                <div class="col-6">
                                    <p class="text-muted small text-uppercase mb-1 fw-semibold">Liên hệ</p>
                                    <p class="fw-medium">@selectedPatient.User?.PhoneNumber</p>
                                </div>
                                <div class="col-6">
                                    <p class="text-muted small text-uppercase mb-1 fw-semibold">Tuổi / Giới tính</p>
                                    <p class="fw-medium">@(selectedPatient.DateOfBirth.HasValue ? (DateTime.Now.Year - selectedPatient.DateOfBirth.Value.Year) : 0) tuổi / @selectedPatient.Gender</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Live Status Card -->
                    <div class="col-md-5">
                        <div class="modern-card glow-card p-4 h-100 d-flex flex-column justify-content-center align-items-center text-center position-relative overflow-hidden">
                            @if (liveData.Any())
                            {
                                <div class="position-absolute top-0 end-0 m-3 d-flex align-items-center gap-2">
                                    <span class="live-indicator"></span>
                                    <span class="text-success fw-bold small text-uppercase" style="letter-spacing: 1px;">Live</span>
                                </div>
                                <h2 class="fw-bold text-dark mb-0" style="font-size: 4rem; color: var(--primary-color) !important;">@(liveData.Last().EMGValue.ToString("0.0"))</h2>
                                <p class="text-muted fw-semibold mt-2">Tín hiệu EMG trực tiếp (µV)</p>
                            }
                            else
                            {
                                <div class="bg-light rounded-circle d-flex justify-content-center align-items-center mb-3" style="width: 80px; height: 80px;">
                                    <i class="bi bi-wifi-off text-muted fs-1"></i>
                                </div>
                                <h5 class="fw-bold">Thiết bị ngoại tuyến</h5>
                                <p class="text-muted small">Đang chờ bệnh nhân kết nối thiết bị và tập luyện...</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Live Chart -->
                <div class="modern-card p-4 mb-4">
                    <h5 class="fw-bold text-dark mb-4">
                        <i class="bi bi-activity text-primary me-2"></i> Dữ liệu EMG Thời gian thực
                    </h5>
                    @if (liveData.Any())
                    {
                        <div style="height: 300px;">
                            <RadzenChart>
                                <RadzenLineSeries Smooth="true" Data="@liveData" CategoryProperty="Time" Title="EMG (µV)" ValueProperty="EMGValue" Stroke="var(--primary-color)">
                                    <RadzenMarkers MarkerType="MarkerType.Circle" Fill="var(--primary-color)" />
                                </RadzenLineSeries>
                                <RadzenCategoryAxis FormatString="{0:HH:mm:ss}" />
                                <RadzenValueAxis>
                                    <RadzenGridLines Visible="true" Stroke="rgba(0,0,0,0.05)" />
                                </RadzenValueAxis>
                            </RadzenChart>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light rounded-4" style="height: 300px;">
                            <div class="text-center text-muted">
                                <i class="bi bi-bar-chart text-muted fs-1 opacity-50 mb-2"></i>
                                <p>Không có dữ liệu telemetry.</p>
                            </div>
                        </div>
                    }
                </div>

                <!-- Exercise History -->
                <div class="modern-card overflow-hidden">
                    <div class="card-header bg-white border-bottom-0 p-4">
                        <h5 class="fw-bold text-dark mb-0">Lịch sử Tập luyện</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted">
                                <tr>
                                    <th class="ps-4 text-uppercase font-weight-semibold small">Ngày</th>
                                    <th class="text-uppercase font-weight-semibold small">Thời lượng</th>
                                    <th class="text-uppercase font-weight-semibold small">Số Reps</th>
                                    <th class="text-uppercase font-weight-semibold small" title="Tầm vận động khớp tối đa đạt được trong buổi tập (Đơn vị: Độ)">Max ROM <i class="bi bi-info-circle text-muted ms-1"></i></th>
                                    <th class="pe-4 text-uppercase font-weight-semibold small">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (selectedPatient.ExerciseSessions != null)
                                {
                                    foreach (var session in selectedPatient.ExerciseSessions.OrderByDescending(s => s.StartTime).Take(5))
                                    {
                                        <tr>
                                            <td class="ps-4 fw-medium text-dark">@session.StartTime.ToString("MMM dd, yyyy")</td>
                                            <td class="text-muted">@session.DurationMinutes min</td>
                                            <td class="fw-bold" style="color: var(--secondary-color);">@session.RepetitionsCount</td>
                                            <td class="text-muted">@session.MaxRom°</td>
                                            <td class="pe-4">
                                                @if (session.RepetitionsCount >= 10)
                                                {
                                                    <span class="badge badge-soft-success rounded-pill px-3 py-2">Tốt</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-soft-warning rounded-pill px-3 py-2">Cần cải thiện</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="modern-card h-100 d-flex flex-column align-items-center justify-content-center p-5 text-center" style="min-height: 60vh;">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex justify-content-center align-items-center mb-4" style="width: 100px; height: 100px;">
                        <i class="bi bi-person-lines-fill text-primary" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="fw-bold text-dark mb-2">Chưa chọn Bệnh nhân</h3>
                    <p class="text-muted mx-auto mb-4" style="max-width: 400px;">
                        Chọn một bệnh nhân từ danh sách bên trái để xem hồ sơ bệnh án, dữ liệu trực tiếp và lịch sử điều trị.
                    </p>
                    <div class="row g-3 w-100" style="max-width: 500px;">
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-4 text-center">
                                <i class="bi bi-activity text-primary fs-3 mb-2 d-block"></i>
                                <div class="small fw-semibold">EMG Live</div>
                                <div class="text-muted" style="font-size:0.75rem;">Xem tín hiệu cơ</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-4 text-center">
                                <i class="bi bi-sliders text-success fs-3 mb-2 d-block"></i>
                                <div class="small fw-semibold">Phác đồ</div>
                                <div class="text-muted" style="font-size:0.75rem;">Chỉnh mục tiêu</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="p-3 bg-light rounded-4 text-center">
                                <i class="bi bi-calendar3 text-info fs-3 mb-2 d-block"></i>
                                <div class="small fw-semibold">Lịch sử</div>
                                <div class="text-muted" style="font-size:0.75rem;">Xem tiến độ</div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Treatment Plan Modal -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(15, 23, 42, 0.6); backdrop-filter: blur(5px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 1.5rem;">
                <div class="modal-header border-0 pt-4 px-4 pb-0">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex justify-content-center align-items-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-sliders text-primary fs-4"></i>
                        </div>
                        <h5 class="modal-title fw-bold mb-0">Điều chỉnh Phác đồ Điều trị</h5>
                    </div>
                </div>
                <div class="modal-body px-4 py-4">
                    <EditForm Model="adjustModel" OnValidSubmit="SaveTreatmentPlan">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark mb-3">Mục tiêu Số lần lặp (mỗi buổi)</label>
                            <div style="padding-right: 60px; position: relative;">
                                <RadzenSlider @bind-Value="adjustModel.TargetRepetitions" Min="5" Max="200" Step="1" style="width: 100%; display: block;" />
                                <div style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); width: 50px; text-align: right;">
                                    <span class="fw-bold fs-5 text-primary">@adjustModel.TargetRepetitions</span>
                                </div>
                            </div>
                            <ValidationMessage For="@(() => adjustModel.TargetRepetitions)" class="text-danger small mt-1 d-block" />
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark mb-3">Mục tiêu Thời lượng (phút)</label>
                            <div style="padding-right: 60px; position: relative;">
                                <RadzenSlider @bind-Value="adjustModel.TargetDuration" Min="5" Max="120" Step="5" style="width: 100%; display: block;" />
                                <div style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); width: 50px; text-align: right;">
                                    <span class="fw-bold fs-5 text-primary">@adjustModel.TargetDuration</span>
                                </div>
                            </div>
                            <ValidationMessage For="@(() => adjustModel.TargetDuration)" class="text-danger small mt-1 d-block" />
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold text-dark">Ghi chú / Hướng dẫn của Bác sĩ</label>
                            <InputTextArea class="form-control bg-light border-0 p-3" style="border-radius: 1rem;" @bind-Value="adjustModel.Description" rows="3" placeholder="Thêm hướng dẫn cụ thể cho bệnh nhân..." />
                            <ValidationMessage For="@(() => adjustModel.Description)" class="text-danger small mt-1 d-block" />
                        </div>
                        
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-light rounded-pill px-4" @onclick="CloseModal">Hủy</button>
                            <button type="submit" class="btn btn-modern-primary rounded-pill px-4 shadow-sm">Lưu phác đồ</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PatientProfile>? patients;
    private PatientProfile? selectedPatient;
    private bool showModal = false;
    private AdjustTreatmentCommand adjustModel = new();
    private string searchQuery = "";

    // Computed: filter patients by name for search
    private List<PatientProfile> filteredPatients =>
        patients == null ? new() :
        string.IsNullOrWhiteSpace(searchQuery) ? patients :
        patients.Where(p => p.User?.FullName?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) == true).ToList();

    // SignalR & Chart
    private HubConnection? hubConnection;
    private List<ChartDataPoint> liveData = new();
    private int currentListeningPatientId = 0;

    private string successMessage = "";
    private bool isSuccessAlert = false; // FIX: Use boolean instead of emoji detection

    protected override async Task OnInitializedAsync()
    {
        try
        {
            patients = await Mediator.Send(new GetPatientsQuery { DoctorId = 0 }); // actual ID resolved in handler from Claims
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching patients: {ex.Message}");
            patients = new List<PatientProfile>();
        }

        // Initialize SignalR Connection
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/dashboardHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<double, double>("ReceiveNewMetrics", (avgEMG, maxROM) =>
        {
            liveData.Add(new ChartDataPoint { Time = DateTime.Now, EMGValue = avgEMG });

            if (liveData.Count > 20) liveData.RemoveAt(0);

            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private async Task SelectPatient(PatientProfile patient)
    {
        selectedPatient = patient;
        
        // Xóa data cũ
        liveData.Clear();
        
        // Chuyển SignalR room nếu đang connect
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            await hubConnection.SendAsync("JoinPatientGroup", patient.PatientId);
            currentListeningPatientId = patient.PatientId;
        }
    }

    private void ShowTreatmentModal()
    {
        if (selectedPatient != null)
        {
            var existingPlan = selectedPatient.TreatmentPlans?.FirstOrDefault();
            
            // Extract DoctorNotes from JSON
            string doctorNotes = "Tiếp tục bài tập hàng ngày.";
            if (existingPlan != null && !string.IsNullOrWhiteSpace(existingPlan.Description))
            {
                if (existingPlan.Description.Trim().StartsWith("{"))
                {
                    try
                    {
                        var planData = System.Text.Json.JsonSerializer.Deserialize<RehabTracking.Web.Features.Healthcare.DoctorDashboard.TreatmentPlanData>(
                            existingPlan.Description, 
                            new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                        if (planData != null && !string.IsNullOrWhiteSpace(planData.DoctorNotes))
                        {
                            doctorNotes = planData.DoctorNotes;
                        }
                    }
                    catch { /* fallback to default if parsing fails */ }
                }
                else
                {
                    doctorNotes = existingPlan.Description; // Legacy plain text
                }
            }

            adjustModel = new AdjustTreatmentCommand
            {
                PlanId = existingPlan?.PlanId ?? 0, 
                PatientId = selectedPatient.PatientId,
                TargetRepetitions = existingPlan?.TargetRepetitions ?? 15,
                TargetDuration = existingPlan?.TargetDuration ?? 20,
                Description = doctorNotes
            };
            showModal = true;
            successMessage = "";
        }
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveTreatmentPlan()
    {
        try
        {
            var result = await Mediator.Send(adjustModel);
            if (result)
            {
                // FIX: Close modal only on SUCCESS, not in finally block
                showModal = false;
                successMessage = RehabTracking.Web.Constants.AppMessages.PlanUpdateSuccess;
                isSuccessAlert = true; // FIX: Set boolean flag
                // Update local state to reflect changes immediately
                var existingPlan = selectedPatient?.TreatmentPlans?.FirstOrDefault();
                if (existingPlan != null)
                {
                    existingPlan.TargetRepetitions = adjustModel.TargetRepetitions;
                    existingPlan.TargetDuration = adjustModel.TargetDuration;
                    existingPlan.Description = adjustModel.Description;
                }
            }
            else
            {
                // FIX: Do NOT close modal on failure - show error instead
                successMessage = RehabTracking.Web.Constants.AppMessages.PlanUpdateFailed;
                isSuccessAlert = false; // FIX: Set boolean flag
            }
        }
        catch (Exception ex)
        {
            successMessage = RehabTracking.Web.Constants.AppMessages.PlanUpdateError;
            isSuccessAlert = false; // FIX: Set boolean flag
            Console.WriteLine($"Error saving plan: {ex.Message}");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    public class ChartDataPoint
    {
        public DateTime Time { get; set; }
        public double EMGValue { get; set; }
    }
}
