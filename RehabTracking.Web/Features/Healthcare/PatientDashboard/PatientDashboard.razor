</div>

<style>
    .live-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: white;
        border-radius: 50%;
        animation: pulse 1s infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }
    .session-timer {
        font-family: 'Inter', monospace;
        font-size: 1.1rem;
        letter-spacing: 0.05em;
    }
    .bg-purple { background-color: #a855f7 !important; }
    .bg-amber { background-color: #d97706 !important; }
</style>

@code {
    private List<ExerciseSession> sessions = new();
    private List<ExerciseSession> todaySessions = new();
    private TreatmentPlan? treatmentPlan;
    private bool isExercising = false;
    private bool isLoading = true;
    private bool isSavingSession = false;
    // FIX B4: Default = false để tránh UI flicker trước khi data load xong
    private bool hasPatientProfile = false;
    private int patientId = 0;
    private string patientName = "Bạn";
    private double currentEMG = 0;
    private string sessionSavedMsg = string.Empty;
    private bool sessionSavedSuccess = false;
    private string parsedDoctorNotes = string.Empty;

    // Computed stats
    private int todayDuration => todaySessions.Sum(s => s.DurationMinutes);
    private int todayReps => todaySessions.Sum(s => s.RepetitionsCount);

    // Voucher copy feedback state (replaces browser alert())
    private string copiedVoucherCode = string.Empty;
    private System.Threading.Timer? _copyFeedbackTimer;

    private void CopyVoucherCode(string code)
    {
        copiedVoucherCode = code;
        // Auto-reset after 2 seconds
        _copyFeedbackTimer?.Dispose();
        _copyFeedbackTimer = new System.Threading.Timer(_ =>
        {
            copiedVoucherCode = string.Empty;
            InvokeAsync(StateHasChanged);
        }, null, 2000, Timeout.Infinite);
    }

    // FIX O3: Cache recoveryScore để tránh tính lại mỗi render
    private int _recoveryScore = 0;
    private int recoveryScore => _recoveryScore;

    private void RecalculateRecoveryScore()
    {
        if (!sessions.Any()) { _recoveryScore = 0; return; }
        var targetReps = treatmentPlan?.TargetRepetitions ?? 30;
        var recentSessions = sessions.OrderByDescending(s => s.StartTime).Take(7).ToList();
        if (!recentSessions.Any()) { _recoveryScore = 0; return; }
        var avgReps = recentSessions.Average(s => s.RepetitionsCount);
        _recoveryScore = (int)Math.Min((avgReps / Math.Max(targetReps, 1)) * 100, 100);
    }

    // Timer - FIX: PeriodicTimer triggers UI re-render every second during exercise
    private DateTime sessionStartTime;
    private CancellationTokenSource? _timerCts;

    // SignalR & Chart
    private HubConnection? hubConnection;
    private List<ChartDataPoint> liveData = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);

        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
        {
            patientId = userId;
        }

        patientName = user.Identity?.Name ?? "Bạn";

        try
        {
            var result = await Mediator.Send(new GetPatientProgressQuery { PatientId = patientId });
            sessions = result.Sessions;
            treatmentPlan = result.TreatmentPlan;
            hasPatientProfile = result.HasPatientProfile;
            todaySessions = sessions.Where(s => s.StartTime.Date == DateTime.UtcNow.Date).ToList();

            if (treatmentPlan != null && !string.IsNullOrWhiteSpace(treatmentPlan.Description))
            {
                if (treatmentPlan.Description.Trim().StartsWith("{"))
                {
                    try
                    {
                        var planData = System.Text.Json.JsonSerializer.Deserialize<RehabTracking.Web.Features.Healthcare.DoctorDashboard.TreatmentPlanData>(
                            treatmentPlan.Description,
                            new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                        if (planData != null && !string.IsNullOrWhiteSpace(planData.DoctorNotes))
                        {
                            parsedDoctorNotes = planData.DoctorNotes;
                        }
                    }
                    catch { /* fallback to default if parsing fails */ }
                }
                else
                {
                    parsedDoctorNotes = treatmentPlan.Description; // Legacy plain text
                }
            }

            // FIX O3: Calculate and cache recovery score after data is loaded
            RecalculateRecoveryScore();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading patient data: {ex.Message}");
            sessions = new();
            todaySessions = new();
            hasPatientProfile = false;
        }

        // Setup SignalR
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/dashboardHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<double, double>("ReceiveNewMetrics", (avgEMG, maxROM) =>
        {
            currentEMG = avgEMG;
            liveData.Add(new ChartDataPoint { Time = DateTime.Now, ROMValue = maxROM });
            if (liveData.Count > 30) liveData.RemoveAt(0);
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        if (patientId > 0)
            await hubConnection.SendAsync("JoinPatientGroup", patientId);

        isLoading = false;
    }

    private void StartSession()
    {
        isExercising = true;
        sessionStartTime = DateTime.Now;
        liveData.Clear();
        sessionSavedMsg = string.Empty;
        _ = SimulateDataLoop();
        // FIX: Start a periodic timer to update the UI timer display every second
        _timerCts = new CancellationTokenSource();
        _ = RunSessionTimerAsync(_timerCts.Token);
    }

    private async Task RunSessionTimerAsync(CancellationToken token)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(token) && isExercising)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* Normal cancellation */ }
    }

    private async Task StopSession()
    {
        isExercising = false;
        // FIX: Cancel the UI timer
        _timerCts?.Cancel();
        _timerCts = null;
        isSavingSession = true;

        var durationMinutes = (int)(DateTime.Now - sessionStartTime).TotalMinutes;

        try
        {
            if (durationMinutes > 0 && patientId > 0)
            {
                var sessionReps = Math.Max(liveData.Count, 1);
                var avgEmg = 0.0;
                var maxRom = liveData.Any() ? (int)liveData.Max(d => d.ROMValue) : 0;

                // BUG FIX: Now saves to DB via MediatR command
                var saved = await Mediator.Send(new SaveSessionCommand
                {
                    PatientId = patientId,
                    StartTime = sessionStartTime,
                    EndTime = DateTime.Now,
                    DurationMinutes = durationMinutes,
                    RepetitionsCount = sessionReps,
                    MaxRom = maxRom,
                    AvgEmg = avgEmg,
                    DeviceType = "Simulator"
                });

                if (saved)
                {
                    var newSession = new ExerciseSession
                    {
                        PatientId = patientId,
                        StartTime = sessionStartTime.ToUniversalTime(),
                        EndTime = DateTime.UtcNow,
                        DurationMinutes = durationMinutes,
                        RepetitionsCount = sessionReps,
                        MaxRom = maxRom,
                        AvgEmg = avgEmg,
                        DeviceType = "Simulator"
                    };
                    sessions.Insert(0, newSession);
                    todaySessions.Insert(0, newSession);
                    // FIX O3: Recalculate cached score after new session is added
                    RecalculateRecoveryScore();
                    sessionSavedMsg = string.Format(AppMessages.SessionSavedSuccessTemplate, durationMinutes);
                    sessionSavedSuccess = true;
                    
                    // Auto-dismiss after 5 seconds
                    _ = Task.Run(async () => 
                    {
                        await Task.Delay(5000);
                        sessionSavedMsg = string.Empty;
                        await InvokeAsync(StateHasChanged);
                    });
                }
                else
                {
                    sessionSavedMsg = AppMessages.SessionSavedError;
                    sessionSavedSuccess = false;
                    
                    _ = Task.Run(async () => 
                    {
                        await Task.Delay(5000);
                        sessionSavedMsg = string.Empty;
                        await InvokeAsync(StateHasChanged);
                    });
                }
            }
            else if (durationMinutes <= 0)
            {
                sessionSavedMsg = AppMessages.SessionTooShort;
                sessionSavedSuccess = false;
                
                _ = Task.Run(async () => 
                {
                    await Task.Delay(5000);
                    sessionSavedMsg = string.Empty;
                    await InvokeAsync(StateHasChanged);
                });
            }
        }
        catch (Exception ex)
        {
            sessionSavedMsg = AppMessages.SessionSaveException;
            sessionSavedSuccess = false;
            Console.WriteLine($"Error saving session: {ex.Message}");
        }
        finally
        {
            isSavingSession = false;
        }
    }

    private string FormatElapsedTime()
    {
        if (!isExercising) return "00:00";
        var elapsed = DateTime.Now - sessionStartTime;
        return $"{(int)elapsed.TotalMinutes:D2}:{elapsed.Seconds:D2}";
    }

    private async Task SimulateDataLoop()
    {
        while (isExercising && hubConnection?.State == HubConnectionState.Connected)
        {
            try
            {
                await hubConnection.SendAsync("SimulateData", patientId);
            }
            catch
            {
                break; // Exit loop if SignalR disconnects
            }
            await Task.Delay(1000);
        }
    }

    public async ValueTask DisposeAsync()
    {
        // FIX: Single cleanup path - removed IDisposable to avoid double-dispose
        _timerCts?.Cancel();
        _timerCts?.Dispose();
        _timerCts = null;
        _copyFeedbackTimer?.Dispose();
        _copyFeedbackTimer = null;
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    // Ranking & Rewards Helpers
    public class VoucherItem
    {
        public string Title { get; set; } = "";
        public string Code { get; set; } = "";
    }

    private int CalculatePoints()
    {
        int exercisePoints = sessions.Sum(s => s.RepetitionsCount * 10 + s.DurationMinutes * 5);
        int streakPoints = CalculateStreak() * 50;
        return exercisePoints + streakPoints;
    }

    private int CalculateStreak()
    {
        if (!sessions.Any()) return 0;
        
        var exerciseDates = sessions
            .Select(s => s.StartTime.ToLocalTime().Date)
            .Distinct()
            .OrderByDescending(d => d)
            .ToList();
            
        if (!exerciseDates.Any()) return 0;
        
        var today = DateTime.Today;
        var yesterday = today.AddDays(-1);
        
        if (exerciseDates[0] != today && exerciseDates[0] != yesterday)
        {
            return 0;
        }
        
        int streak = 0;
        var currentCheckDate = exerciseDates[0];
        
        foreach (var date in exerciseDates)
        {
            if (date == currentCheckDate)
            {
                streak++;
                currentCheckDate = currentCheckDate.AddDays(-1);
            }
            else
            {
                break;
            }
        }
        
        return streak;
    }

    private int GetRankTier(int points)
    {
        if (points >= 8000) return 4;
        if (points >= 4000) return 3;
        if (points >= 1500) return 2;
        if (points >= 500) return 1;
        return 0;
    }

    private string GetRankName(int tier)
    {
        return tier switch
        {
            4 => "KIM CƯƠNG",
            3 => "BẠCH KIM",
            2 => "VÀNG",
            1 => "BẠC",
            _ => "ĐỒNG"
        };
    }

    private string GetRankIcon(int tier)
    {
        return tier switch
        {
            4 => "bi-gem",
            3 => "bi-award-fill",
            2 => "bi-trophy-fill",
            1 => "bi-bookmark-star-fill",
            _ => "bi-award"
        };
    }

    private string GetRankGradient(int tier)
    {
        return tier switch
        {
            4 => "linear-gradient(135deg, #a855f7 0%, #d946ef 100%)",
            3 => "linear-gradient(135deg, #0ea5e9 0%, #3b82f6 100%)",
            2 => "linear-gradient(135deg, #eab308 0%, #f97316 100%)",
            1 => "linear-gradient(135deg, #94a3b8 0%, #cbd5e1 100%)",
            _ => "linear-gradient(135deg, #b45309 0%, #d97706 100%)"
        };
    }

    private string GetRankProgressBarClass(int tier)
    {
        return tier switch
        {
            4 => "bg-purple",
            3 => "bg-primary",
            2 => "bg-warning",
            1 => "bg-secondary",
            _ => "bg-amber"
        };
    }

    private int GetNextRankThreshold(int tier)
    {
        return tier switch
        {
            3 => 8000,
            2 => 4000,
            1 => 1500,
            0 => 500,
            _ => 99999 // Diamond max – used for progress bar max only
        };
    }

    private double GetRankProgressPercentage(int points)
    {
        int tier = GetRankTier(points);
        int currentBase = tier switch
        {
            4 => 8000,
            3 => 4000,
            2 => 1500,
            1 => 500,
            _ => 0
        };
        int nextGoal = GetNextRankThreshold(tier);
        if (nextGoal == 99999) return 100.0;
        
        double progress = (double)(points - currentBase) / (nextGoal - currentBase) * 100.0;
        return Math.Clamp(progress, 0.0, 100.0);
    }

    private string GetNextRankMessage(int points)
    {
        int tier = GetRankTier(points);
        if (tier == 4) return "🏆 Bạn đã đạt cấp bậc KIM CƯƠNG cao nhất!";
        int pointsNeeded = GetNextRankThreshold(tier) - points;
        string nextRank = GetRankName(tier + 1);
        return $"Còn {pointsNeeded:#,0} điểm để lên hạng {nextRank}";
    }

    private string GetAdFrequencyMessage(int tier)
    {
        return tier switch
        {
            4 => "Tắt 100%",
            3 => "Tắt 100%",
            2 => "Tắt 100%",
            1 => "Giảm 60%",
            _ => "Mặc định"
        };
    }

    private List<VoucherItem> GetVouchers(int tier)
    {
        var vouchers = new List<VoucherItem>();
        vouchers.Add(new VoucherItem { Title = "Giảm 10k mua phụ kiện", Code = "STEPWELCOME10" });
        if (tier >= 1)
        {
            vouchers.Add(new VoucherItem { Title = "Giảm 30k gói Đặc Quyền", Code = "STEPSILVER30" });
        }
        if (tier >= 2)
        {
            vouchers.Add(new VoucherItem { Title = "Giảm 50k thiết bị mới", Code = "STEPGOLD50" });
        }
        if (tier >= 3)
        {
            vouchers.Add(new VoucherItem { Title = "Miễn phí 1 tháng tập VIP", Code = "STEPPLATINUMFREE" });
        }
        return vouchers;
    }

