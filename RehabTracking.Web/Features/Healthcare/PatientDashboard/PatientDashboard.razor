@page "/patient-dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Patient")]
@using MediatR
@using RehabTracking.Web.Entities
@using RehabTracking.Web.Features.Healthcare.PatientDashboard
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Radzen.Blazor
@using RehabTracking.Web.Constants
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Sức khỏe của tôi - STEP</PageTitle>

<div class="container-fluid py-4">
    @if (isLoading)
    {
        <div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;" role="status"></div>
                <p class="text-muted fw-medium">@AppMessages.LoadingData</p>
            </div>
        </div>
    }
    else if (!hasPatientProfile)
    {
        <!-- No device activated yet -->
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="modern-card p-5 text-center">
                    <div class="mb-4">
                        <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex justify-content-center align-items-center" style="width:100px;height:100px;">
                            <i class="bi bi-watch text-warning" style="font-size:3rem;"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold text-dark mb-2">@AppMessages.WelcomePrefix @patientName!</h3>
                    <p class="text-muted mb-4">@AppMessages.NoDeviceActivated</p>
                    <a href="/activate-device" class="btn btn-modern-primary btn-lg rounded-pill px-5 shadow">
                        <i class="bi bi-watch me-2"></i>Kích hoạt thiết bị ngay
                    </a>
                    <div class="mt-4 text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        Mã Serial nằm ở mặt sau vòng đeo tay RehabBand của bạn.
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Hero Welcome -->
        <div class="row mb-4 align-items-center">
            <div class="col-lg-8">
                <h1 class="fw-bold mb-1" style="font-size: 2rem; color: var(--text-main);">
                    @AppMessages.WelcomePrefix <span style="color: var(--primary-color);">@patientName</span>! 👋
                </h1>
                <p class="text-muted mb-0">
                    @if (sessions.Any())
                    {
                        <span>@AppMessages.ProgressGood</span>
                    }
                    else
                    {
                        <span>@AppMessages.ProgressStartToday</span>
                    }
                </p>
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-medium" style="font-size:0.8rem;">
                        <i class="bi bi-calendar-check me-1"></i>@sessions.Count buổi đã tập
                    </span>
                    @if (treatmentPlan != null)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-medium" style="font-size:0.8rem;">
                            <i class="bi bi-clipboard2-pulse me-1"></i>Đang trong phác đồ điều trị
                        </span>
                    }
                </div>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0 d-flex gap-2 justify-content-lg-end flex-wrap">
                <a href="/patient/workout" class="btn btn-outline-primary btn-lg rounded-pill fw-semibold shadow-sm">
                    <i class="bi bi-calendar-check me-1"></i> Bài tập hôm nay
                </a>
                @if (!isExercising)
                {
                    <button class="btn btn-modern btn-modern-primary btn-lg shadow-sm" @onclick="StartSession">
                        <i class="bi bi-play-fill fs-5 me-1"></i> Bắt đầu Nhanh
                    </button>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-lg-end gap-3">
                        <div class="text-success fw-bold">
                            <i class="bi bi-stopwatch me-1"></i>
                            <span class="session-timer">@FormatElapsedTime()</span>
                        </div>
                        <button class="btn btn-danger btn-lg rounded-pill shadow-sm fw-semibold" @onclick="StopSession" disabled="@isSavingSession">
                            @if (isSavingSession)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Đang lưu...</span>
                            }
                            else
                            {
                                <i class="bi bi-stop-fill fs-5 me-1"></i>
                                <span>Dừng tập</span>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Session saved notification -->
        @if (!string.IsNullOrEmpty(sessionSavedMsg))
        {
            <div class="alert @(sessionSavedSuccess ? "alert-success" : "alert-warning") alert-dismissible border-0 rounded-3 d-flex align-items-center gap-2 mb-4 fade-in" role="alert">
                <i class="bi @(sessionSavedSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") flex-shrink-0"></i>
                <span>@sessionSavedMsg</span>
                <button type="button" class="btn-close" @onclick="() => sessionSavedMsg = string.Empty"></button>
            </div>
        }

        @if (isExercising)
        {
            <div class="modern-card p-3 mb-4 d-flex align-items-center gap-3"
                 style="background: linear-gradient(135deg, rgba(16,185,129,0.08), rgba(16,185,129,0.03)); border: 1px solid rgba(16,185,129,0.2);">
                <div class="spinner-grow text-success flex-shrink-0" role="status" style="width: 1.2rem; height: 1.2rem;"></div>
                <div>
                    <h6 class="fw-bold text-success mb-0">Thiết bị Đang kết nối &amp; Phát sóng</h6>
                    <p class="text-muted mb-0 small">Đang truyền góc gập cổ tay (ROM) theo thời gian thực đến bác sĩ của bạn.</p>
                </div>
                <div class="ms-auto text-end">
                    <div class="text-success fw-bold">@(liveData.LastOrDefault()?.ROMValue.ToString("0") ?? "0")°</div>
                    <div class="text-muted small cursor-pointer" data-tooltip="Tầm vận động cổ tay hiện tại">Góc gập hiện tại <i class="bi bi-info-circle ms-1"></i></div>
                </div>
            </div>
        }

        <!-- Progress Cards -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="modern-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h6 class="text-muted fw-semibold text-uppercase mb-0" style="font-size: 0.78rem; letter-spacing: 0.05em;">Thời gian tập hôm nay</h6>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                            <i class="bi bi-clock-history fs-5"></i>
                        </div>
                    </div>
                    <div class="d-flex align-items-baseline gap-2">
                        <h2 class="fw-bold text-dark mb-0" style="font-size: 2.8rem;">@todayDuration</h2>
                        <span class="text-muted fw-medium">phút</span>
                    </div>
                    <div class="progress mt-3" style="height: 4px; border-radius: 2px; background-color: rgba(79,70,229,0.1);">
                        <div class="progress-bar bg-primary" style="width: @(Math.Min(todayDuration * 100 / Math.Max(treatmentPlan?.TargetDuration ?? 30, 1), 100))%; transition: width 0.5s ease;"></div>
                    </div>
                    <div class="text-muted small mt-1">Mục tiêu: @(treatmentPlan?.TargetDuration ?? 30) phút</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="modern-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-muted fw-semibold text-uppercase mb-0" style="font-size: 0.78rem; letter-spacing: 0.05em;">Số lần lặp hợp lệ</h6>
                        <div class="bg-success bg-opacity-10 p-2 rounded-3 text-success">
                            <i class="bi bi-arrow-repeat fs-5"></i>
                        </div>
                    </div>
                    <div class="d-flex align-items-baseline gap-2">
                        <h2 class="fw-bold text-success mb-0" style="font-size: 2.8rem;">@todayReps</h2>
                        <span class="text-muted fw-medium">lần</span>
                    </div>
                    <div class="progress mt-3" style="height: 4px; border-radius: 2px; background-color: rgba(16,185,129,0.1);">
                        <div class="progress-bar bg-success" style="width: @(Math.Min(todayReps * 100 / Math.Max(treatmentPlan?.TargetRepetitions ?? 30, 1), 100))%; transition: width 0.5s ease;"></div>
                    </div>
                    <div class="text-muted small mt-1">Mục tiêu: @(treatmentPlan?.TargetRepetitions ?? 30) lần</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="modern-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-muted fw-semibold text-uppercase mb-0" style="font-size: 0.78rem; letter-spacing: 0.05em;">Điểm Phục hồi</h6>
                        <div class="bg-info bg-opacity-10 p-2 rounded-3 text-info">
                            <i class="bi bi-activity fs-5"></i>
                        </div>
                    </div>
                    <div class="d-flex align-items-baseline gap-2 mb-2">
                        <h2 class="fw-bold text-info mb-0" style="font-size: 2.8rem;">@recoveryScore</h2>
                        <span class="text-muted fw-medium">%</span>
                    </div>
                    <div class="progress" style="height: 6px; border-radius: 3px; background-color: rgba(14,165,233,0.1);">
                        <div class="progress-bar bg-info" role="progressbar"
                             style="width: @recoveryScore%; border-radius: 3px; transition: width 0.5s ease;"
                             aria-valuenow="@recoveryScore" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="text-muted small mt-1">
                        @if (recoveryScore >= 80)
                        {
                            <i class="bi bi-trophy-fill text-warning me-1"></i><span>Xuất sắc!</span>
                        }
                        else if (recoveryScore >= 60)
                        {
                            <i class="bi bi-hand-thumbs-up-fill text-success me-1"></i><span>Tốt</span>
                        }
                        else if (recoveryScore > 0)
                        {
                            <i class="bi bi-arrow-up-circle-fill text-primary me-1"></i><span>Cố gắng lên!</span>
                        }
                        else
                        {
                            <i class="bi bi-bar-chart-fill text-muted me-1"></i><span>Chưa có dữ liệu</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Ranking & Rewards Section -->
        <div class="row g-4 mb-4">
            <!-- Ranking Card -->
            <div class="col-lg-6">
                <div class="modern-card p-4 h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); border: 1px solid rgba(255,255,255,0.05);">
                    <div class="position-absolute top-0 end-0 m-3 text-white-50 opacity-10">
                        <i class="bi bi-award-fill" style="font-size: 8rem;"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
                        <h5 class="fw-bold text-white mb-0">
                            <i class="bi bi-award text-warning me-2"></i> Xếp hạng &amp; Điểm thưởng
                        </h5>
                        <span class="badge bg-warning text-dark fw-bold rounded-pill px-3 py-2">
                            Chuỗi tập: @CalculateStreak() ngày 🔥
                        </span>
                    </div>

                    <div class="row align-items-center">
                        <div class="col-sm-5 text-center mb-3 mb-sm-0 border-end border-secondary border-opacity-25">
                            <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3 p-3 shadow-lg" 
                                 style="width: 90px; height: 90px; background: @GetRankGradient(GetRankTier(CalculatePoints())); border: 3px solid rgba(255,255,255,0.15);">
                                <i class="bi @GetRankIcon(GetRankTier(CalculatePoints())) text-white fs-1"></i>
                            </div>
                            <h3 class="fw-bold text-white mb-1">@GetRankName(GetRankTier(CalculatePoints()))</h3>
                            <p class="text-white-50 small mb-0">Hạng Thành viên</p>
                        </div>
                        <div class="col-sm-7 ps-sm-4">
                            <div class="mb-3">
                                <div class="d-flex justify-content-between text-white-50 small mb-1">
                                    <span>Tổng điểm tích lũy</span>
                                    @if (GetRankTier(CalculatePoints()) >= 4)
                                    {
                                        <span class="text-warning fw-bold">@CalculatePoints() ✨ Tối đa</span>
                                    }
                                    else
                                    {
                                        <span class="text-white fw-bold">@CalculatePoints() / @GetNextRankThreshold(GetRankTier(CalculatePoints())) điểm</span>
                                    }
                                </div>
                                <div class="progress bg-secondary bg-opacity-20" style="height: 8px; border-radius: 4px;">
                                    <div class="progress-bar @GetRankProgressBarClass(GetRankTier(CalculatePoints()))" role="progressbar" 
                                         style="width: @(GetRankProgressPercentage(CalculatePoints()))%; border-radius: 4px; transition: width 0.5s ease;"></div>
                                </div>
                            </div>
                            <ul class="list-unstyled text-white-50 small mb-0 d-flex flex-column gap-2">
                                <li class="d-flex align-items-center">
                                    <i class="bi bi-check2 text-success me-2"></i>
                                    <span>Tập luyện hôm nay: <strong class="text-white">+@(todayReps * 10 + todayDuration * 5) điểm</strong></span>
                                </li>
                                <li class="d-flex align-items-center">
                                    <i class="bi bi-check2 text-success me-2"></i>
                                    <span>Điểm thưởng chuỗi (x50): <strong class="text-white">@(CalculateStreak() * 50) điểm</strong></span>
                                </li>
                                <li class="d-flex align-items-start">
                                    <i class="bi bi-info-circle text-info mt-1 me-2"></i>
                                    <span class="text-info text-start">@GetNextRankMessage(CalculatePoints())</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Ad Block & Rewards Card -->
            <div class="col-lg-6">
                <div class="modern-card p-4 h-100 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
                            <h5 class="fw-bold text-dark mb-0">
                                <i class="bi bi-shield-check text-primary me-2"></i> Ưu đãi theo Thứ hạng
                            </h5>
                            <span class="badge @(GetRankTier(CalculatePoints()) >= 2 ? "bg-success" : "bg-primary") rounded-pill px-3 py-2">
                                <i class="bi bi-badge-ad me-1"></i> QC: @GetAdFrequencyMessage(GetRankTier(CalculatePoints()))
                            </span>
                        </div>

                        <!-- Vouchers -->
                        <div class="mb-4 text-start">
                            <h6 class="fw-bold text-dark small text-uppercase mb-3">Voucher Ưu đãi đã Mở khóa</h6>
                            <div class="row g-2">
                                @foreach (var voucher in GetVouchers(GetRankTier(CalculatePoints())))
                                {
                                    <div class="col-sm-6">
                                        <div class="p-3 border border-dashed rounded-4 d-flex justify-content-between align-items-center" style="background: rgba(79,70,229,0.03); border-color: rgba(79,70,229,0.2) !important;">
                                            <div class="text-start">
                                                <div class="fw-bold text-dark mb-0 small" style="font-size:0.8rem;">@voucher.Title</div>
                                                <span class="text-muted" style="font-size: 0.72rem;">Code: <strong class="text-primary font-monospace">@voucher.Code</strong></span>
                                            </div>
                                            <button class="btn btn-sm btn-outline-primary rounded-pill px-3 flex-shrink-0" @onclick="() => CopyVoucherCode(voucher.Code)"
                                                    title="Sao chép mã voucher">
                                                @if (copiedVoucherCode == voucher.Code)
                                                {
                                                    <i class="bi bi-check-lg text-success me-1"></i><span class="text-success">Đã copy!</span>
                                                }
                                                else
                                                {
                                                    <span><i class="bi bi-copy me-1"></i>Copy</span>
                                                }
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Live Ad Banner (Dynamic based on rank) -->
                    @if (GetRankTier(CalculatePoints()) < 2)
                    {
                        <div class="p-3 bg-light rounded-4 border border-light d-flex align-items-center gap-3">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-4 d-flex justify-content-center align-items-center fs-2 flex-shrink-0" style="width: 50px; height: 50px;">
                                <i class="bi bi-bag-check-fill"></i>
                            </div>
                            <div class="flex-grow-1 text-start" style="min-width: 0;">
                                <div class="fw-bold text-dark text-truncate" style="font-size: 0.9rem;">Mua RehabBand V2 - Trả góp 0%</div>
                                <p class="text-muted mb-0 small text-truncate">Cảm biến góc khớp MPU6050 thế hệ mới, kết nối nhạy bén 10x.</p>
                            </div>
                            <a href="/#products" class="btn btn-sm btn-primary rounded-pill flex-shrink-0">Mua ngay</a>
                        </div>
                    }
                    else
                    {
                        <div class="p-3 rounded-4 d-flex align-items-center gap-3 text-success border border-success border-opacity-10" style="background: rgba(16,185,129,0.05);">
                            <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center fs-3 flex-shrink-0" style="width: 44px; height: 44px;">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                            <div class="text-start">
                                <div class="fw-bold text-dark" style="font-size: 0.9rem;">Bạn đã được Tắt quảng cáo 100%!</div>
                                <p class="text-muted mb-0 small">Quyền lợi dành cho thành viên Hạng Vàng trở lên. Cảm ơn sự nỗ lực tập luyện của bạn!</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Chart & Plan -->
        <div class="row g-4 mb-4">
            <!-- Live Chart -->
            <div class="col-lg-8">
                <div class="modern-card glow-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold text-dark mb-0">
                            <i class="bi bi-graph-up-arrow text-primary me-2"></i> Góc gập cổ tay thời gian thực (ROM)
                        </h5>
                        @if (isExercising)
                        {
                            <span class="badge bg-success rounded-pill px-3 py-2">
                                <span class="live-dot me-1"></span> LIVE
                            </span>
                        }
                    </div>

                    @if (!liveData.Any() && !isExercising)
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light rounded-4" style="height:320px;">
                            <div class="text-center text-muted p-4">
                                <i class="bi bi-activity text-muted" style="font-size:4rem;opacity:0.2;"></i>
                                <h5 class="mt-3 fw-bold">@AppMessages.NoDataYet</h5>
                                <p class="small">@AppMessages.ClickToStart</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="rounded-4 overflow-hidden" style="height: 320px;">
                            <RadzenChart Style="width: 100%; height: 100%;">
                                <RadzenLineSeries Smooth="true" Data="@liveData" CategoryProperty="Time" ValueProperty="ROMValue"
                                                  Title="Góc gập (°)" Stroke="var(--primary-color)" StrokeWidth="2.5">
                                    <RadzenSeriesDataLabels Visible="false" />
                                    <RadzenMarkers MarkerType="MarkerType.None" />
                                </RadzenLineSeries>
                                <RadzenCategoryAxis FormatString="{0:HH:mm:ss}" />
                                <RadzenValueAxis Min="0" Max="180">
                                    <RadzenGridLines Visible="true" Stroke="rgba(0,0,0,0.04)" />
                                </RadzenValueAxis>
                            </RadzenChart>
                        </div>
                    }
                </div>
            </div>

            <!-- Treatment Plan -->
            <div class="col-lg-4">
                <div class="modern-card h-100 d-flex flex-column">
                    <div class="p-4 border-bottom">
                        <h5 class="fw-bold text-dark mb-0">
                            <i class="bi bi-clipboard2-pulse text-primary me-2"></i> Mục tiêu hôm nay
                        </h5>
                    </div>
                    <div class="p-4 flex-grow-1">
                        @if (treatmentPlan != null)
                        {
                            <div class="d-flex flex-column gap-3 mb-4">
                                <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                                            <i class="bi bi-arrow-repeat fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Số lần lặp</h6>
                                            <span class="text-muted small">Mục tiêu mỗi buổi</span>
                                        </div>
                                    </div>
                                    <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold">@treatmentPlan.TargetRepetitions lần</span>
                                </div>

                                <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                                            <i class="bi bi-clock fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Thời gian</h6>
                                            <span class="text-muted small">Mục tiêu mỗi buổi</span>
                                        </div>
                                    </div>
                                    <span class="badge bg-success rounded-pill px-3 py-2 fw-bold">@treatmentPlan.TargetDuration phút</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(parsedDoctorNotes))
                            {
                                <div class="p-3 rounded-4" style="background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(245,158,11,0.04)); border: 1px solid rgba(245,158,11,0.2);">
                                    <div class="d-flex align-items-start gap-2">
                                        <i class="bi bi-chat-quote-fill fs-4 flex-shrink-0" style="color: var(--warning-color);"></i>
                                        <div>
                                            <h6 class="fw-bold text-dark mb-1 small text-uppercase">Lời nhắn từ Bác sĩ</h6>
                                            <p class="mb-0 small text-muted fst-italic">"@parsedDoctorNotes"</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-clipboard2 fs-1 opacity-30 mb-3 d-block"></i>
