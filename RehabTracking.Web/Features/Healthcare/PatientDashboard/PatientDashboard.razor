@page "/patient-dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Patient")]
@using MediatR
@using RehabTracking.Web.Entities
@using RehabTracking.Web.Features.Healthcare.PatientDashboard
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Radzen.Blazor
@using RehabTracking.Web.Constants
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Dashboard Bệnh nhân - STEP</PageTitle>

<div class="container-fluid py-4">
    @if (isLoading)
    {
        <div class="d-flex align-items-center justify-content-center" style="min-height: 60vh;">
            <div class="text-center">
                <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;" role="status"></div>
                <p class="text-muted fw-medium">@AppMessages.LoadingData</p>
            </div>
        </div>
    }
    else if (!hasPatientProfile)
    {
        <!-- No device activated yet -->
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="modern-card p-5 text-center">
                    <div class="mb-4">
                        <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex justify-content-center align-items-center" style="width:100px;height:100px;">
                            <i class="bi bi-watch text-warning" style="font-size:3rem;"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold text-dark mb-2">@AppMessages.WelcomePrefix @patientName!</h3>
                    <p class="text-muted mb-4">@AppMessages.NoDeviceActivated</p>
                    <a href="/activate-device" class="btn btn-modern-primary btn-lg rounded-pill px-5 shadow">
                        <i class="bi bi-watch me-2"></i>Kích hoạt thiết bị ngay
                    </a>
                    <div class="mt-4 text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        Mã Serial nằm ở mặt sau vòng đeo tay RehabBand của bạn.
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <!-- Hero Welcome -->
        <div class="row mb-4 align-items-center">
            <div class="col-lg-8">
                <h1 class="fw-bold mb-1" style="font-size: 2rem; color: var(--text-main);">
                    @AppMessages.WelcomePrefix <span style="color: var(--primary-color);">@patientName</span>! 👋
                </h1>
                <p class="text-muted mb-0">
                    @if (sessions.Any())
                    {
                        <span>@AppMessages.ProgressGood</span>
                    }
                    else
                    {
                        <span>@AppMessages.ProgressStartToday</span>
                    }
                </p>
                <div class="d-flex gap-2 mt-3 flex-wrap">
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 fw-medium" style="font-size:0.8rem;">
                        <i class="bi bi-calendar-check me-1"></i>@sessions.Count buổi đã tập
                    </span>
                    @if (treatmentPlan != null)
                    {
                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-medium" style="font-size:0.8rem;">
                            <i class="bi bi-clipboard2-pulse me-1"></i>Đang trong phác đồ điều trị
                        </span>
                    }
                </div>
            </div>
            <div class="col-lg-4 text-lg-end mt-3 mt-lg-0 d-flex gap-2 justify-content-lg-end flex-wrap">
                <a href="/patient/workout" class="btn btn-outline-primary btn-lg rounded-pill fw-semibold shadow-sm">
                    <i class="bi bi-dumbbell me-1"></i> Bài tập hôm nay
                </a>
                @if (!isExercising)
                {
                    <button class="btn btn-modern btn-modern-primary btn-lg shadow-sm" @onclick="StartSession">
                        <i class="bi bi-play-fill fs-5 me-1"></i> Bắt đầu Nhanh
                    </button>
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-lg-end gap-3">
                        <div class="text-success fw-bold">
                            <i class="bi bi-stopwatch me-1"></i>
                            <span class="session-timer">@FormatElapsedTime()</span>
                        </div>
                        <button class="btn btn-danger btn-lg rounded-pill shadow-sm fw-semibold" @onclick="StopSession" disabled="@isSavingSession">
                            @if (isSavingSession)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                <span>Đang lưu...</span>
                            }
                            else
                            {
                                <i class="bi bi-stop-fill fs-5 me-1"></i>
                                <span>Dừng tập</span>
                            }
                        </button>
                    </div>
                }
            </div>
        </div>

        <!-- Session saved notification -->
        @if (!string.IsNullOrEmpty(sessionSavedMsg))
        {
            <div class="alert @(sessionSavedSuccess ? "alert-success" : "alert-warning") alert-dismissible border-0 rounded-3 d-flex align-items-center gap-2 mb-4 fade-in" role="alert">
                <i class="bi @(sessionSavedSuccess ? "bi-check-circle-fill" : "bi-exclamation-triangle-fill") flex-shrink-0"></i>
                <span>@sessionSavedMsg</span>
                <button type="button" class="btn-close" @onclick="() => sessionSavedMsg = string.Empty"></button>
            </div>
        }

        @if (isExercising)
        {
            <div class="modern-card p-3 mb-4 d-flex align-items-center gap-3"
                 style="background: linear-gradient(135deg, rgba(16,185,129,0.08), rgba(16,185,129,0.03)); border: 1px solid rgba(16,185,129,0.2);">
                <div class="spinner-grow text-success flex-shrink-0" role="status" style="width: 1.2rem; height: 1.2rem;"></div>
                <div>
                    <h6 class="fw-bold text-success mb-0">Thiết bị Đang kết nối &amp; Phát sóng</h6>
                    <p class="text-muted mb-0 small">Đang truyền tín hiệu EMG &amp; IMU theo thời gian thực đến bác sĩ của bạn.</p>
                </div>
                <div class="ms-auto text-end">
                    <div class="text-success fw-bold">@currentEMG.ToString("0.0") µV</div>
                    <div class="text-muted small cursor-pointer" data-tooltip="Hoạt động điện cơ (Càng cao càng tốt)">EMG hiện tại <i class="bi bi-info-circle ms-1"></i></div>
                </div>
            </div>
        }

        <!-- Progress Cards -->
        <div class="row g-4 mb-4">
            <div class="col-md-4">
                <div class="modern-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h6 class="text-muted fw-semibold text-uppercase mb-0" style="font-size: 0.78rem; letter-spacing: 0.05em;">Thời gian tập hôm nay</h6>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 text-primary">
                            <i class="bi bi-clock-history fs-5"></i>
                        </div>
                    </div>
                    <div class="d-flex align-items-baseline gap-2">
                        <h2 class="fw-bold text-dark mb-0" style="font-size: 2.8rem;">@todayDuration</h2>
                        <span class="text-muted fw-medium">phút</span>
                    </div>
                    <div class="progress mt-3" style="height: 4px; border-radius: 2px; background-color: rgba(79,70,229,0.1);">
                        <div class="progress-bar bg-primary" style="width: @(Math.Min(todayDuration * 100 / Math.Max(treatmentPlan?.TargetDuration ?? 30, 1), 100))%; transition: width 0.5s ease;"></div>
                    </div>
                    <div class="text-muted small mt-1">Mục tiêu: @(treatmentPlan?.TargetDuration ?? 30) phút</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="modern-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-muted fw-semibold text-uppercase mb-0" style="font-size: 0.78rem; letter-spacing: 0.05em;">Số lần lặp hợp lệ</h6>
                        <div class="bg-success bg-opacity-10 p-2 rounded-3 text-success">
                            <i class="bi bi-arrow-repeat fs-5"></i>
                        </div>
                    </div>
                    <div class="d-flex align-items-baseline gap-2">
                        <h2 class="fw-bold text-success mb-0" style="font-size: 2.8rem;">@todayReps</h2>
                        <span class="text-muted fw-medium">lần</span>
                    </div>
                    <div class="progress mt-3" style="height: 4px; border-radius: 2px; background-color: rgba(16,185,129,0.1);">
                        <div class="progress-bar bg-success" style="width: @(Math.Min(todayReps * 100 / Math.Max(treatmentPlan?.TargetRepetitions ?? 30, 1), 100))%; transition: width 0.5s ease;"></div>
                    </div>
                    <div class="text-muted small mt-1">Mục tiêu: @(treatmentPlan?.TargetRepetitions ?? 30) lần</div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="modern-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h6 class="text-muted fw-semibold text-uppercase mb-0" style="font-size: 0.78rem; letter-spacing: 0.05em;">Điểm Phục hồi</h6>
                        <div class="bg-info bg-opacity-10 p-2 rounded-3 text-info">
                            <i class="bi bi-activity fs-5"></i>
                        </div>
                    </div>
                    <div class="d-flex align-items-baseline gap-2 mb-2">
                        <h2 class="fw-bold text-info mb-0" style="font-size: 2.8rem;">@recoveryScore</h2>
                        <span class="text-muted fw-medium">%</span>
                    </div>
                    <div class="progress" style="height: 6px; border-radius: 3px; background-color: rgba(14,165,233,0.1);">
                        <div class="progress-bar bg-info" role="progressbar"
                             style="width: @recoveryScore%; border-radius: 3px; transition: width 0.5s ease;"
                             aria-valuenow="@recoveryScore" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <div class="text-muted small mt-1">
                        @if (recoveryScore >= 80)
                        {
                            <i class="bi bi-trophy-fill text-warning me-1"></i><span>Xuất sắc!</span>
                        }
                        else if (recoveryScore >= 60)
                        {
                            <i class="bi bi-hand-thumbs-up-fill text-success me-1"></i><span>Tốt</span>
                        }
                        else if (recoveryScore > 0)
                        {
                            <i class="bi bi-arrow-up-circle-fill text-primary me-1"></i><span>Cố gắng lên!</span>
                        }
                        else
                        {
                            <i class="bi bi-bar-chart-fill text-muted me-1"></i><span>Chưa có dữ liệu</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart & Plan -->
        <div class="row g-4 mb-4">
            <!-- Live Chart -->
            <div class="col-lg-8">
                <div class="modern-card glow-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold text-dark mb-0">
                            <i class="bi bi-graph-up-arrow text-primary me-2"></i> Hoạt động cơ theo thời gian thực (EMG)
                        </h5>
                        @if (isExercising)
                        {
                            <span class="badge bg-success rounded-pill px-3 py-2">
                                <span class="live-dot me-1"></span> LIVE
                            </span>
                        }
                    </div>

                    @if (!liveData.Any() && !isExercising)
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light rounded-4" style="height:320px;">
                            <div class="text-center text-muted p-4">
                                <i class="bi bi-activity text-muted" style="font-size:4rem;opacity:0.2;"></i>
                                <h5 class="mt-3 fw-bold">@AppMessages.NoDataYet</h5>
                                <p class="small">@AppMessages.ClickToStart</p>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="rounded-4 overflow-hidden" style="height: 320px;">
                            <RadzenChart Style="width: 100%; height: 100%;">
                                <RadzenLineSeries Smooth="true" Data="@liveData" CategoryProperty="Time" ValueProperty="EMGValue"
                                                  Title="EMG (µV)" Stroke="var(--primary-color)" StrokeWidth="2.5">
                                    <RadzenSeriesDataLabels Visible="false" />
                                    <RadzenMarkers MarkerType="MarkerType.None" />
                                </RadzenLineSeries>
                                <RadzenCategoryAxis FormatString="{0:HH:mm:ss}" />
                                <RadzenValueAxis>
                                    <RadzenGridLines Visible="true" Stroke="rgba(0,0,0,0.04)" />
                                </RadzenValueAxis>
                            </RadzenChart>
                        </div>
                    }
                </div>
            </div>

            <!-- Treatment Plan -->
            <div class="col-lg-4">
                <div class="modern-card h-100 d-flex flex-column">
                    <div class="p-4 border-bottom">
                        <h5 class="fw-bold text-dark mb-0">
                            <i class="bi bi-clipboard2-pulse text-primary me-2"></i> Mục tiêu hôm nay
                        </h5>
                    </div>
                    <div class="p-4 flex-grow-1">
                        @if (treatmentPlan != null)
                        {
                            <div class="d-flex flex-column gap-3 mb-4">
                                <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                                            <i class="bi bi-arrow-repeat fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Số lần lặp</h6>
                                            <span class="text-muted small">Mục tiêu mỗi buổi</span>
                                        </div>
                                    </div>
                                    <span class="badge bg-primary rounded-pill px-3 py-2 fw-bold">@treatmentPlan.TargetRepetitions lần</span>
                                </div>

                                <div class="p-3 bg-light rounded-4 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                                            <i class="bi bi-clock fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-0">Thời gian</h6>
                                            <span class="text-muted small">Mục tiêu mỗi buổi</span>
                                        </div>
                                    </div>
                                    <span class="badge bg-success rounded-pill px-3 py-2 fw-bold">@treatmentPlan.TargetDuration phút</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(parsedDoctorNotes))
                            {
                                <div class="p-3 rounded-4" style="background: linear-gradient(135deg, rgba(245,158,11,0.08), rgba(245,158,11,0.04)); border: 1px solid rgba(245,158,11,0.2);">
                                    <div class="d-flex align-items-start gap-2">
                                        <i class="bi bi-chat-quote-fill fs-4 flex-shrink-0" style="color: var(--warning-color);"></i>
                                        <div>
                                            <h6 class="fw-bold text-dark mb-1 small text-uppercase">Lời nhắn từ Bác sĩ</h6>
                                            <p class="mb-0 small text-muted fst-italic">"@parsedDoctorNotes"</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4 text-muted">
                                <i class="bi bi-clipboard2 fs-1 opacity-30 mb-3 d-block"></i>
                                <p class="small">@AppMessages.NoTreatmentPlan</p>
                            </div>
                        }
                    </div>

                    <!-- Today's sessions mini list -->
                    @if (todaySessions.Any())
                    {
                        <div class="p-4 border-top">
                            <div class="text-muted small fw-semibold text-uppercase mb-2">Buổi tập hôm nay</div>
                            @foreach (var s in todaySessions.Take(3))
                            {
                                <div class="d-flex justify-content-between align-items-center py-1">
                                    <span class="small text-muted">@s.StartTime.ToLocalTime().ToString("HH:mm")</span>
                                    <span class="small">@s.DurationMinutes phút · @s.RepetitionsCount lần</span>
                                    @if (s.RepetitionsCount >= (treatmentPlan?.TargetRepetitions ?? 10))
                                    {
                                        <span class="badge badge-soft-success rounded-pill px-2">Tốt</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-soft-warning rounded-pill px-2">Cố gắng</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Weekly Achievement -->
        <div class="modern-card p-4 mb-4" style="background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%); border: 1px solid rgba(79,70,229,0.15);">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <h5 class="fw-bold text-dark mb-0">
                    <i class="bi bi-trophy-fill text-warning me-2"></i>Thành tích tuần này
                </h5>
                <span class="badge bg-white text-primary rounded-pill px-3 py-2 shadow-sm fw-semibold" style="font-size:0.8rem;">
                    @{ var weekStart = DateTime.UtcNow.AddDays(-7); }
                    @sessions.Count(s => s.StartTime >= weekStart) / 7 ngày
                </span>
            </div>
            <div class="row g-3">
                <div class="col-4">
                    <div class="bg-white rounded-4 p-3 text-center shadow-sm">
                        <div class="fw-bold text-primary" style="font-size:1.8rem;">@sessions.Count(s => s.StartTime >= weekStart)</div>
                        <div class="text-muted small fw-semibold">Buổi tập</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="bg-white rounded-4 p-3 text-center shadow-sm">
                        <div class="fw-bold text-success" style="font-size:1.8rem;">@sessions.Where(s => s.StartTime >= weekStart).Sum(s => s.DurationMinutes)</div>
                        <div class="text-muted small fw-semibold">Phút tập</div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="bg-white rounded-4 p-3 text-center shadow-sm">
                        <div class="fw-bold text-info" style="font-size:1.8rem;">@sessions.Where(s => s.StartTime >= weekStart).Sum(s => s.RepetitionsCount)</div>
                        <div class="text-muted small fw-semibold">Lần lặp</div>
                    </div>
                </div>
            </div>
            @if (recoveryScore >= 80)
            {
                <div class="mt-3 p-3 bg-white rounded-4 d-flex align-items-center gap-3 shadow-sm">
                    <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;flex-shrink:0;">
                        <i class="bi bi-star-fill text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark">Xuất sắc! 🎉</div>
                        <div class="text-muted small">Bạn đang đạt điểm phục hồi xuất sắc. Tiếp tục phát huy nhé!</div>
                    </div>
                </div>
            }
            else if (recoveryScore >= 50)
            {
                <div class="mt-3 p-3 bg-white rounded-4 d-flex align-items-center gap-3 shadow-sm">
                    <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;flex-shrink:0;">
                        <i class="bi bi-hand-thumbs-up-fill text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark">Tiến bộ tốt! 💪</div>
                        <div class="text-muted small">Bạn đang trên đà phục hồi. Cố gắng hoàn thành mục tiêu mỗi ngày!</div>
                    </div>
                </div>
            }
            else
            {
                <div class="mt-3 p-3 bg-white rounded-4 d-flex align-items-center gap-3 shadow-sm">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center" style="width:44px;height:44px;flex-shrink:0;">
                        <i class="bi bi-lightning-charge-fill text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-bold text-dark">Hãy bắt đầu hành trình!</div>
                        <div class="text-muted small">Mỗi buổi tập đều quan trọng. Hôm nay là ngày tốt để bắt đầu.</div>
                    </div>
                </div>
            }
        </div>

        <!-- Exercise History Table -->
        <div class="modern-card overflow-hidden mb-4">
            <div class="card-header bg-white border-bottom-0 p-4 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold text-dark mb-0">
                    <i class="bi bi-calendar3 text-primary me-2"></i>Lịch sử Tập luyện (30 ngày gần nhất)
                </h5>
                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">@sessions.Count buổi</span>
            </div>
            @if (sessions.Any())
            {
                <!-- Weekly Progress Summary -->
                <div class="px-4 pb-3">
                    <div class="row g-2">
                        @for (int d = 6; d >= 0; d--)
                        {
                            var day = DateTime.UtcNow.AddDays(-d);
                            var daySessions = sessions.Where(s => s.StartTime.Date == day.Date).ToList();
                            var dayReps = daySessions.Sum(s => s.RepetitionsCount);
                            var isToday = d == 0;
                            var hasData = daySessions.Any();
                            var targetReps = treatmentPlan?.TargetRepetitions ?? 30;
                            var fillPct = Math.Min(dayReps * 100 / Math.Max(targetReps, 1), 100);
                            var col = d;
                            <div class="col" style="min-width: 0;">
                                <div class="text-center">
                                    <div class="small text-muted mb-1" style="font-size:0.7rem;">@day.ToString("ddd").ToUpper()</div>
                                    <div class="position-relative mx-auto" style="width:36px; height:60px; background:#f1f5f9; border-radius:8px; overflow:hidden;">
                                        <div class="position-absolute bottom-0 start-0 w-100"
                                             style="height:@fillPct%; background: @(hasData ? (fillPct >= 100 ? "#10b981" : "#4f46e5") : "#e2e8f0"); border-radius:6px; transition: height 0.5s ease;"></div>
                                    </div>
                                    <div class="small mt-1" style="font-size:0.7rem; font-weight:@(isToday ? "bold" : "normal"); color:@(isToday ? "#4f46e5" : "#94a3b8");">@day.Day</div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="d-flex justify-content-between mt-2">
                        <span class="text-muted" style="font-size:0.72rem;"><span style="display:inline-block;width:10px;height:10px;background:#10b981;border-radius:2px;"></span> Đạt mục tiêu</span>
                        <span class="text-muted" style="font-size:0.72rem;"><span style="display:inline-block;width:10px;height:10px;background:#4f46e5;border-radius:2px;"></span> Chưa đủ</span>
                        <span class="text-muted" style="font-size:0.72rem;"><span style="display:inline-block;width:10px;height:10px;background:#e2e8f0;border-radius:2px;"></span> Nghỉ</span>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light text-muted">
                            <tr>
                                <th class="ps-4 text-uppercase small">Ngày tập</th>
                                <th class="text-uppercase small">Thời lượng</th>
                                <th class="text-uppercase small">Số Reps</th>
                                <th class="text-uppercase small cursor-pointer" data-tooltip="Tầm vận động khớp tối đa">Max ROM <i class="bi bi-info-circle"></i></th>
                                <th class="text-uppercase small cursor-pointer" data-tooltip="Hoạt động điện cơ trung bình">EMG TB <i class="bi bi-info-circle"></i></th>
                                <th class="pe-4 text-uppercase small">Kết quả</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var session in sessions.Take(10))
                            {
                                <tr>
                                    <td class="ps-4 fw-medium text-dark">@session.StartTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-muted">@session.DurationMinutes phút</td>
                                    <td class="fw-bold" style="color: var(--secondary-color);">@session.RepetitionsCount</td>
                                    <td class="text-muted">@session.MaxRom°</td>
                                    <td class="text-muted">@session.AvgEmg.ToString("0.0") µV</td>
                                    <td class="pe-4">
                                        @if (session.RepetitionsCount >= (treatmentPlan?.TargetRepetitions ?? 10))
                                        {
                                            <span class="badge badge-soft-success rounded-pill px-3 py-2">
                                                <i class="bi bi-check-circle-fill me-1"></i>Hoàn thành
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-soft-warning rounded-pill px-3 py-2">
                                                <i class="bi bi-exclamation-circle me-1"></i>Cần cải thiện
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-calendar-x fs-1 opacity-30 mb-3 d-block"></i>
                    <p>@AppMessages.NoHistory</p>
                </div>
            }
        </div>
    }
</div>

<style>
    .live-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        background: white;
        border-radius: 50%;
        animation: pulse 1s infinite;
    }
    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.3; }
    }
    .session-timer {
        font-family: 'Inter', monospace;
        font-size: 1.1rem;
        letter-spacing: 0.05em;
    }
</style>

@code {
    private List<ExerciseSession> sessions = new();
    private List<ExerciseSession> todaySessions = new();
    private TreatmentPlan? treatmentPlan;
    private bool isExercising = false;
    private bool isLoading = true;
    private bool isSavingSession = false;
    // FIX B4: Default = false để tránh UI flicker trước khi data load xong
    private bool hasPatientProfile = false;
    private int patientId = 0;
    private string patientName = "Bạn";
    private double currentEMG = 0;
    private string sessionSavedMsg = string.Empty;
    private bool sessionSavedSuccess = false;
    private string parsedDoctorNotes = string.Empty;

    // Computed stats
    private int todayDuration => todaySessions.Sum(s => s.DurationMinutes);
    private int todayReps => todaySessions.Sum(s => s.RepetitionsCount);

    // FIX O3: Cache recoveryScore để tránh tính lại mỗi render
    private int _recoveryScore = 0;
    private int recoveryScore => _recoveryScore;

    private void RecalculateRecoveryScore()
    {
        if (!sessions.Any()) { _recoveryScore = 0; return; }
        var targetReps = treatmentPlan?.TargetRepetitions ?? 30;
        var recentSessions = sessions.OrderByDescending(s => s.StartTime).Take(7).ToList();
        if (!recentSessions.Any()) { _recoveryScore = 0; return; }
        var avgReps = recentSessions.Average(s => s.RepetitionsCount);
        _recoveryScore = (int)Math.Min((avgReps / Math.Max(targetReps, 1)) * 100, 100);
    }

    // Timer - FIX: PeriodicTimer triggers UI re-render every second during exercise
    private DateTime sessionStartTime;
    private CancellationTokenSource? _timerCts;

    // SignalR & Chart
    private HubConnection? hubConnection;
    private List<ChartDataPoint> liveData = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);

        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
        {
            patientId = userId;
        }

        patientName = user.Identity?.Name ?? "Bạn";

        try
        {
            var result = await Mediator.Send(new GetPatientProgressQuery { PatientId = patientId });
            sessions = result.Sessions;
            treatmentPlan = result.TreatmentPlan;
            hasPatientProfile = result.HasPatientProfile;
            todaySessions = sessions.Where(s => s.StartTime.Date == DateTime.UtcNow.Date).ToList();

            if (treatmentPlan != null && !string.IsNullOrWhiteSpace(treatmentPlan.Description))
            {
                if (treatmentPlan.Description.Trim().StartsWith("{"))
                {
                    try
                    {
                        var planData = System.Text.Json.JsonSerializer.Deserialize<RehabTracking.Web.Features.Healthcare.DoctorDashboard.TreatmentPlanData>(
                            treatmentPlan.Description,
                            new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                        if (planData != null && !string.IsNullOrWhiteSpace(planData.DoctorNotes))
                        {
                            parsedDoctorNotes = planData.DoctorNotes;
                        }
                    }
                    catch { /* fallback to default if parsing fails */ }
                }
                else
                {
                    parsedDoctorNotes = treatmentPlan.Description; // Legacy plain text
                }
            }

            // FIX O3: Calculate and cache recovery score after data is loaded
            RecalculateRecoveryScore();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading patient data: {ex.Message}");
            sessions = new();
            todaySessions = new();
            hasPatientProfile = false;
        }

        // Setup SignalR
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/dashboardHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<double, double>("ReceiveNewMetrics", (avgEMG, maxROM) =>
        {
            currentEMG = avgEMG;
            liveData.Add(new ChartDataPoint { Time = DateTime.Now, EMGValue = avgEMG });
            if (liveData.Count > 30) liveData.RemoveAt(0);
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        if (patientId > 0)
            await hubConnection.SendAsync("JoinPatientGroup", patientId);

        isLoading = false;
    }

    private void StartSession()
    {
        isExercising = true;
        sessionStartTime = DateTime.Now;
        liveData.Clear();
        sessionSavedMsg = string.Empty;
        _ = SimulateDataLoop();
        // FIX: Start a periodic timer to update the UI timer display every second
        _timerCts = new CancellationTokenSource();
        _ = RunSessionTimerAsync(_timerCts.Token);
    }

    private async Task RunSessionTimerAsync(CancellationToken token)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await timer.WaitForNextTickAsync(token) && isExercising)
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* Normal cancellation */ }
    }

    private async Task StopSession()
    {
        isExercising = false;
        // FIX: Cancel the UI timer
        _timerCts?.Cancel();
        _timerCts = null;
        isSavingSession = true;

        var durationMinutes = (int)(DateTime.Now - sessionStartTime).TotalMinutes;

        try
        {
            if (durationMinutes > 0 && patientId > 0)
            {
                var sessionReps = Math.Max(liveData.Count, 1);
                var avgEmg = liveData.Any() ? liveData.Average(d => d.EMGValue) : 0;
                var maxRom = liveData.Any() ? (int)(liveData.Max(d => d.EMGValue) / 2) : 0;

                // BUG FIX: Now saves to DB via MediatR command
                var saved = await Mediator.Send(new SaveSessionCommand
                {
                    PatientId = patientId,
                    StartTime = sessionStartTime,
                    EndTime = DateTime.Now,
                    DurationMinutes = durationMinutes,
                    RepetitionsCount = sessionReps,
                    MaxRom = maxRom,
                    AvgEmg = avgEmg,
                    DeviceType = "Simulator"
                });

                if (saved)
                {
                    var newSession = new ExerciseSession
                    {
                        PatientId = patientId,
                        StartTime = sessionStartTime.ToUniversalTime(),
                        EndTime = DateTime.UtcNow,
                        DurationMinutes = durationMinutes,
                        RepetitionsCount = sessionReps,
                        MaxRom = maxRom,
                        AvgEmg = avgEmg,
                        DeviceType = "Simulator"
                    };
                    sessions.Insert(0, newSession);
                    todaySessions.Insert(0, newSession);
                    // FIX O3: Recalculate cached score after new session is added
                    RecalculateRecoveryScore();
                    sessionSavedMsg = string.Format(AppMessages.SessionSavedSuccessTemplate, durationMinutes);
                    sessionSavedSuccess = true;
                }
                else
                {
                    sessionSavedMsg = AppMessages.SessionSavedError;
                    sessionSavedSuccess = false;
                }
            }
            else if (durationMinutes <= 0)
            {
                sessionSavedMsg = AppMessages.SessionTooShort;
                sessionSavedSuccess = false;
            }
        }
        catch (Exception ex)
        {
            sessionSavedMsg = AppMessages.SessionSaveException;
            sessionSavedSuccess = false;
            Console.WriteLine($"Error saving session: {ex.Message}");
        }
        finally
        {
            isSavingSession = false;
        }
    }

    private string FormatElapsedTime()
    {
        if (!isExercising) return "00:00";
        var elapsed = DateTime.Now - sessionStartTime;
        return $"{(int)elapsed.TotalMinutes:D2}:{elapsed.Seconds:D2}";
    }

    private async Task SimulateDataLoop()
    {
        while (isExercising && hubConnection?.State == HubConnectionState.Connected)
        {
            try
            {
                await hubConnection.SendAsync("SimulateData", patientId);
            }
            catch
            {
                break; // Exit loop if SignalR disconnects
            }
            await Task.Delay(1000);
        }
    }

    public async ValueTask DisposeAsync()
    {
        // FIX: Single cleanup path - removed IDisposable to avoid double-dispose
        _timerCts?.Cancel();
        _timerCts?.Dispose();
        _timerCts = null;
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }

    public class ChartDataPoint
    {
        public DateTime Time { get; set; }
        public double EMGValue { get; set; }
    }
}
