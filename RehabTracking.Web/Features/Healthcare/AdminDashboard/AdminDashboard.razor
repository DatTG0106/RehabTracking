@page "/admin-dashboard"
@using Microsoft.AspNetCore.Authorization
@using MediatR
@using RehabTracking.Web.Entities
@using RehabTracking.Web.Features.Healthcare.AdminDashboard
@attribute [Authorize(Roles = "Admin")]
@inject IMediator Mediator
@rendermode InteractiveServer

<PageTitle>Admin Dashboard - STEP</PageTitle>

<div class="container-fluid py-4">
    <!-- Hero Section -->
    <div class="row mb-5 align-items-center">
        <div class="col-lg-8">
            <h1 class="fw-bold mb-1" style="color: var(--text-main); font-size: 2.5rem;">Trung Tâm Xử Lý Đơn Hàng</h1>
            <p class="text-muted fs-5">Quản lý và xuất kho thiết bị STEP Smart Glove. Đảm bảo bảo mật toàn bộ dữ liệu y khoa của bệnh nhân.</p>
        </div>
        <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
            <div class="d-inline-flex gap-3">
                <div class="bg-white px-4 py-3 rounded-4 shadow-sm text-center border-0">
                    <h2 class="fw-bold text-primary mb-0">@(orders?.Count ?? 0)</h2>
                    <span class="text-muted small fw-semibold text-uppercase tracking-wide">Chờ xử lý</span>
                </div>
                <div class="bg-white px-4 py-3 rounded-4 shadow-sm text-center border-0">
                    <h2 class="fw-bold text-success mb-0">@shippedTodayCount</h2>
                    <span class="text-muted small fw-semibold text-uppercase tracking-wide">Đã giao hôm nay</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Success/Error Alert with auto-dismiss -->
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success alert-dismissible border-0 rounded-3 d-flex align-items-center gap-2 mb-4 fade-in" role="alert">
            <i class="bi bi-check-circle-fill flex-shrink-0 fs-5"></i>
            <span>@successMessage</span>
            <button type="button" class="btn-close ms-auto" @onclick="() => successMessage = string.Empty"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(globalErrorMessage))
    {
        <div class="alert alert-danger alert-dismissible border-0 rounded-3 d-flex align-items-center gap-2 mb-4 fade-in" role="alert">
            <i class="bi bi-exclamation-triangle-fill flex-shrink-0 fs-5"></i>
            <span>@globalErrorMessage</span>
            <button type="button" class="btn-close ms-auto" @onclick="() => globalErrorMessage = string.Empty"></button>
        </div>
    }

    <!-- Data Table Card -->
    <div class="row g-4">
        <div class="col-12">
            <div class="modern-card p-0 overflow-hidden">
                <div class="card-header bg-white border-bottom pt-4 pb-3 px-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
                        <div>
                            <h5 class="fw-bold text-dark mb-0">Danh Sách Đơn Hàng</h5>
                            <p class="text-muted small mb-0 mt-1">Gán mã Serial để kích hoạt thiết bị STEP trước khi giao hàng cho khách</p>
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <!-- Search -->
                            <div class="input-group" style="width: 220px;">
                                <span class="input-group-text bg-light border-end-0 rounded-start-3">
                                    <i class="bi bi-search text-muted"></i>
                                </span>
                                <input type="text" class="form-control bg-light border-start-0 rounded-end-3"
                                       placeholder="Tìm kiếm..."
                                       @bind="orderSearch" @bind:event="oninput" />
                            </div>
                            <!-- Status Filter -->
                            <select class="form-select rounded-3" style="width: 160px;" @bind="statusFilter">
                                <option value="">Tất cả trạng thái</option>
                                <option value="Pending">Chờ xử lý</option>
                                <option value="Shipped">Giao thành công</option>
                                <option value="Processing">Trong kho</option>
                            </select>
                            <button class="btn btn-light rounded-3 px-3" @onclick="LoadOrders" disabled="@isRefreshing" title="Làm mới">
                                @if (isRefreshing)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                }
                                else
                                {
                                    <i class="bi bi-arrow-clockwise"></i>
                                }
                            </button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(orderSearch) || !string.IsNullOrEmpty(statusFilter))
                    {
                        <div class="mt-3 d-flex align-items-center gap-2">
                            <span class="badge bg-primary rounded-pill">@filteredOrders.Count kết quả</span>
                            <button class="btn btn-sm btn-link text-muted text-decoration-none p-0" @onclick="ClearFilters">
                                <i class="bi bi-x-circle me-1"></i>Xóa bộ lọc
                            </button>
                        </div>
                    }
                </div>
                <div class="card-body p-0">
                    @if (orders == null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
                            <p class="text-muted mt-3 fw-medium">Đang tải dữ liệu...</p>
                        </div>
                    }
                    else if (!orders.Any())
                    {
                        <div class="text-center py-5 bg-light">
                            <div class="bg-white rounded-circle d-inline-flex justify-content-center align-items-center shadow-sm mb-3" style="width: 80px; height: 80px;">
                                <i class="bi bi-check2-all text-success" style="font-size: 2.5rem;"></i>
                            </div>
                            <h4 class="fw-bold">Hoàn tất!</h4>
                            <p class="text-muted">Không có đơn hàng nào đang chờ xử lý.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0 border-top">
                                <thead class="table-light text-muted">
                                    <tr>
                                        <th class="ps-4 py-3 text-uppercase" style="font-size: 0.85rem;">Mã ĐH</th>
                                        <th class="py-3 text-uppercase" style="font-size: 0.85rem;">Thông Tin Khách Hàng</th>
                                        <th class="py-3 text-uppercase" style="font-size: 0.85rem;">Ngày Đặt</th>
                                        <th class="py-3 text-uppercase" style="font-size: 0.85rem;">Tổng Tiền</th>
                                        <th class="py-3 text-uppercase" style="font-size: 0.85rem;">Trạng Thái</th>
                                        <th class="pe-4 py-3 text-end text-uppercase" style="font-size: 0.85rem;">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!filteredOrders.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-5">
                                                <i class="bi bi-search fs-1 opacity-25 mb-2 d-block"></i>
                                                Không tìm thấy đơn hàng nào khớp với bộ lọc.
                                            </td>
                                        </tr>
                                    }
                                    @foreach (var order in filteredOrders)
                                    {
                                        <tr style="transition: all 0.2s;">
                                            <td class="ps-4 fw-bold text-dark">#@order.OrderId</td>
                                            <td>
                                                <div class="fw-semibold text-dark">@order.Customer?.FullName</div>
                                                <div class="text-muted small d-flex align-items-center mt-1">
                                                    <i class="bi bi-geo-alt-fill me-1 text-danger"></i> @order.ShippingAddress
                                                </div>
                                            </td>
                                            <td class="text-muted">
                                                <div class="d-flex align-items-center">
                                                    <i class="bi bi-calendar-event me-2"></i>
                                                    @(order.OrderDate?.ToString("dd/MM/yyyy") ?? "N/A")
                                                </div>
                                            </td>
                                            <td class="fw-bold" style="color: var(--primary-color);">@order.TotalAmount.ToString("N0")₫</td>
                                            <td>
                                                <span class="badge badge-soft-warning px-3 py-2 rounded-pill">
                                                    <i class="bi bi-clock-history me-1"></i> @order.Status
                                                </span>
                                            </td>
                                            <td class="pe-4 text-end">
                                                <button class="btn btn-modern-primary rounded-pill btn-sm px-3 shadow-sm" @onclick="() => OpenProcessModal(order)">
                                                    <i class="bi bi-cpu me-1"></i> Gán Serial
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal for assigning IoT MAC Address -->
@if (selectedOrder != null && showProcessModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(15, 23, 42, 0.6); backdrop-filter: blur(5px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 1.5rem;">
                <div class="modal-header border-0 pt-4 px-4 pb-0">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex justify-content-center align-items-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-cpu-fill text-primary fs-4"></i>
                        </div>
                        <div>
                            <h5 class="modal-title fw-bold mb-0">Gán Thiết Bị cho Đơn hàng</h5>
                            <span class="text-muted small">Đơn hàng #@selectedOrder.OrderId · @selectedOrder.Customer?.FullName</span>
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseProcessModal"></button>
                </div>
                <div class="modal-body px-4 py-4">
                    <p class="text-muted">Nhập địa chỉ MAC hoặc số Serial của thiết bị ESP32 trước khi giao hàng cho khách.</p>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger border-0 rounded-3 py-2 d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            @errorMessage
                        </div>
                    }

                    <div class="form-floating mb-2">
                        <input type="text" class="form-control" id="macInput" placeholder="VD: 00:1B:44:11:3A:B7"
                               @bind="deviceSerialNumber" @bind:event="oninput" style="border-radius: 0.75rem;"
                               maxlength="50" />
                        <label for="macInput">Mã MAC / Serial Thiết Bị</label>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <div class="text-muted small d-flex align-items-center">
                            <i class="bi bi-info-circle me-1 text-primary"></i> Khách hàng sẽ dùng mã này để kích hoạt thiết bị.
                        </div>
                        <small class="text-muted">@(deviceSerialNumber.Length)/50</small>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" @onclick="CloseProcessModal">Hủy</button>
                    <button type="button" class="btn btn-modern-primary rounded-pill px-4"
                            @onclick="SubmitProcessOrder"
                            disabled="@(string.IsNullOrWhiteSpace(deviceSerialNumber) || deviceSerialNumber.Trim().Length < 6 || isSubmitting)">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            <span>Đang xử lý...</span>
                        }
                        else
                        {
                            <i class="bi bi-send-check me-2"></i>
                            <span>Xác nhận &amp; Giao Hàng</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Order>? orders;
    private string orderSearch = string.Empty;
    private string statusFilter = string.Empty;

    // Computed filtered list
    private List<Order> filteredOrders
    {
        get
        {
            if (orders == null) return new();
            var q = orders.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(orderSearch))
            {
                var term = orderSearch.Trim();
                q = q.Where(o =>
                    (o.Customer?.FullName?.Contains(term, StringComparison.OrdinalIgnoreCase) == true) ||
                    o.OrderId.ToString().Contains(term) ||
                    (o.ShippingAddress?.Contains(term, StringComparison.OrdinalIgnoreCase) == true));
            }
            if (!string.IsNullOrWhiteSpace(statusFilter))
            {
                q = q.Where(o => o.Status?.Equals(statusFilter, StringComparison.OrdinalIgnoreCase) == true);
            }
            return q.ToList();
        }
    }

    private void ClearFilters()
    {
        orderSearch = string.Empty;
        statusFilter = string.Empty;
    }

    private int shippedTodayCount = 0;
    private Order? selectedOrder;
    private bool showProcessModal = false;
    private bool isRefreshing = false;
    private bool isSubmitting = false;
    private string deviceSerialNumber = "";
    private string errorMessage = "";
    private string successMessage = "";
    private string globalErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isRefreshing = true;
        try
        {
            orders = await Mediator.Send(new GetPendingOrdersQuery());
            // BUG FIX: Load shipped today count from actual DB query instead of local counter
            shippedTodayCount = await Mediator.Send(new GetShippedTodayCountQuery());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching orders: {ex.Message}");
            globalErrorMessage = RehabTracking.Web.Constants.AppMessages.ErrorOccurred;
            orders = new List<Order>();
        }
        finally
        {
            isRefreshing = false;
        }
    }

    private void OpenProcessModal(Order order)
    {
        selectedOrder = order;
        deviceSerialNumber = "";
        errorMessage = "";
        showProcessModal = true;
    }

    private void CloseProcessModal()
    {
        showProcessModal = false;
        selectedOrder = null;
        errorMessage = "";
    }

    private async Task SubmitProcessOrder()
    {
        if (selectedOrder == null || string.IsNullOrWhiteSpace(deviceSerialNumber)) return;

        if (deviceSerialNumber.Trim().Length < 6)
        {
            errorMessage = RehabTracking.Web.Constants.AppMessages.InvalidSerialLength;
            return;
        }

        isSubmitting = true;
        errorMessage = "";

        try
        {
            var result = await Mediator.Send(new ProcessOrderCommand
            {
                OrderId = selectedOrder.OrderId,
                DeviceSerialNumber = deviceSerialNumber.Trim()
            });

            if (result)
            {
                var orderId = selectedOrder.OrderId;
                var serial = deviceSerialNumber.Trim();
                CloseProcessModal();
                successMessage = string.Format(RehabTracking.Web.Constants.AppMessages.OrderProcessedSuccessTemplate, orderId, serial);
                await LoadOrders(); // Refresh list and update shippedTodayCount from DB
            }
            else
            {
                errorMessage = RehabTracking.Web.Constants.AppMessages.OrderFailed;
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message.Length < 200 ? ex.Message : RehabTracking.Web.Constants.AppMessages.ErrorOccurred;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
