    <!-- FAQ Section -->
    <div id="faq" class="py-5" style="background-color: #f8fafc;">
        <div class="container py-4">
            <div class="text-center mb-5">
                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-2">
                    <i class="bi bi-question-circle me-1"></i> Giải đáp thắc mắc
                </span>
                <h2 class="fw-bold">Câu hỏi thường gặp (FAQ)</h2>
                <p class="text-muted">Tổng hợp những câu hỏi người dùng thường gặp khi sử dụng hệ thống.</p>
            </div>
            
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <!-- FIX: Blazor-native accordion, not Bootstrap JS (compatible with InteractiveServer) -->
                    <div class="accordion-flush bg-white rounded-4 shadow-sm overflow-hidden">
                        @{
                            var faqItems = new[]
                            {
                                ("faq1", "Thiết bị có tương thích với điện thoại của tôi không?",
                                 "Thiết bị sử dụng kết nối WiFi và Bluetooth chuẩn mới nhất, hoàn toàn tương thích với mọi thiết bị di động (iOS, Android), máy tính bảng, và laptop có trình duyệt web hiện đại. Không cần cài thêm driver hay phần mềm bổ sung."),
                                ("faq2", "Bác sĩ có thể theo dõi tôi theo thời gian thực không?",
                                 "Hoàn toàn có thể. Nhờ công nghệ SignalR, dữ liệu góc gập (ROM) của bạn sẽ được truyền trực tiếp đến màn hình của bác sĩ chuyên khoa với độ trễ chưa tới 1 giây. Bác sĩ có thể theo dõi hàng trăm bệnh nhân cùng lúc từ xa."),
                                ("faq3", "Chính sách bảo hành như thế nào?",
                                 "Tất cả thiết bị STEP đều được bảo hành chính hãng 1 đổi 1 trong vòng 12 tháng đối với lỗi từ nhà sản xuất. Đội ngũ kỹ thuật hỗ trợ 24/7 qua hotline và trực tiếp tại trung tâm dịch vụ."),
                                ("faq4", "Dữ liệu y tế của tôi có được bảo mật không?",
                                 "Chắc chắn. Chúng tôi sử dụng chuẩn mã hóa AES-256 và HTTPS/TLS 1.3 để bảo vệ dữ liệu sức khỏe của bạn theo tiêu chuẩn HIPAA. Dữ liệu chỉ được truy cập bởi bạn và bác sĩ chuyên khoa được chỉ định. Chúng tôi không bao giờ bán hay chia sẻ dữ liệu cá nhân."),
                                ("faq5", "Tôi có cần kỹ năng kỹ thuật để sử dụng thiết bị không?",
                                 "Không cần. Thiết bị được thiết kế để người cao tuổi và người không rành công nghệ vẫn có thể sử dụng dễ dàng. Chỉ cần 3 bước: Đeo vòng đeo tay → Bật nguồn → Nhấn \"Bắt đầu\" trên ứng dụng. Thiết bị tự động kết nối và truyền dữ liệu."),
                                ("faq6", "Mất bao lâu để thấy kết quả phục hồi?",
                                 "Tùy theo mức độ tổn thương ban đầu, đa số bệnh nhân nhận thấy cải thiện rõ rệt sau 4-8 tuần tập luyện đúng phác đồ. Hệ thống sẽ tự động ghi nhận tiến trình và thông báo cho bác sĩ khi bạn đạt các mốc phục hồi quan trọng.")
                            };
                        }
                        @foreach (var (id, question, answer) in faqItems)
                        {
                            var isOpen = activeFaq == id;
                            <div class="border-bottom" style="@(isOpen ? "background-color: #fafbff;" : "")">
                                <button class="w-100 text-start d-flex justify-content-between align-items-center px-4 py-3 bg-transparent border-0 fw-bold text-dark"
                                        style="font-family: 'Inter', sans-serif; font-size: 0.95rem; cursor: pointer;"
                                        @onclick='() => ToggleFaq(id)'>
                                    <span>@question</span>
                                    <i class="bi @(isOpen ? "bi-chevron-up text-primary" : "bi-chevron-down text-muted") ms-3 flex-shrink-0" style="transition: transform 0.2s;"></i>
                                </button>
                                @if (isOpen)
                                {
                                    <div class="px-4 pb-4 text-muted" style="line-height: 1.7; animation: fadeInUp 0.2s ease-out;">
                                        @answer
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Blog & Medical Articles Section -->
    <div class="py-5" style="background-color: #f8fafc;">
