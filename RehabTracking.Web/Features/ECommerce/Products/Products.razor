@page "/"
@using MediatR
@using RehabTracking.Web.Entities
@using RehabTracking.Web.Features.ECommerce.Products
@using RehabTracking.Web.Features.ECommerce.Cart
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject IMediator Mediator
@inject CartState CartState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider
@rendermode InteractiveServer

<PageTitle>STEP - Kết nối bệnh nhân, bác sĩ và quá trình phục hồi</PageTitle>

<div class="container-fluid p-0">
    <!-- Hero Section / Landing Page -->
    <div class="hero-section text-white text-center py-5">
        <div class="container py-5 mt-4">
            <div class="hero-badge mb-4 animate-fade-in-up">
                <i class="bi bi-award-fill me-2 text-warning"></i> Hệ thống theo dõi và hỗ trợ phục hồi chức năng tại nhà bằng thiết bị đeo thông minh
            </div>
            <h1 class="display-3 fw-black mb-4 animate-fade-in-up" style="animation-delay: 0.1s; letter-spacing: -1px;">
                Theo dõi <span class="text-info">đúng lúc</span> - Phục hồi <span class="text-info">đúng cách</span>
            </h1>
            <p class="lead mb-5 opacity-90 mx-auto animate-fade-in-up" style="max-width: 680px; font-weight: 300; animation-delay: 0.2s; line-height: 1.8;">
                Đội ngũ bác sĩ chuyên khoa và công nghệ <strong class="fw-bold">cảm biến y sinh tiên tiến</strong> cùng đồng hành — giúp bạn phục hồi nhanh hơn, tập luyện thông minh hơn, và sống trọn vẹn hơn ngay tại nhà.
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap mb-4">
                <button @onclick='() => ScrollTo("products")' class="btn btn-light btn-lg rounded-pill fw-bold text-primary px-5 shadow">
                    <i class="bi bi-grid me-2"></i>Xem Thiết Bị
                </button>
                <button @onclick='() => ScrollTo("how-it-works")' class="btn btn-outline-light btn-lg rounded-pill px-5">
                    <i class="bi bi-play-circle me-2"></i>Cách hoạt động
                </button>
            </div>
            <!-- Live trust indicator -->
            <div class="d-flex justify-content-center gap-4 flex-wrap animate-fade-in-up" style="animation-delay: 0.4s; opacity: 0.85;">
                <div class="d-flex align-items-center gap-2">
                    <span class="position-relative d-inline-block">
                        <span class="badge bg-success rounded-circle p-1" style="width:10px;height:10px;"></span>
                    </span>
                    <span style="font-size:0.85rem;">Giám sát trực tiếp 24/7</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-shield-check text-success"></i>
                    <span style="font-size:0.85rem;">Đạt chuẩn y tế quốc tế</span>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-patch-check text-warning"></i>
                    <span style="font-size:0.85rem;">Được kiểm chứng lâm sàng</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Trusted Partners Logo Bar -->
    <div class="bg-light py-4 border-bottom position-relative z-1" style="margin-top: -30px; border-radius: 20px 20px 0 0;">
        <div class="container">
            <p class="text-center text-muted small fw-bold text-uppercase mb-3">Đơn vị hợp tác chuyên môn</p>
            <div class="d-flex justify-content-center align-items-center opacity-75">
                <h5 class="fw-bold text-secondary mb-0"><i class="bi bi-hospital me-2"></i>Bệnh viện Hoàn Mỹ Cửu Long</h5>
            </div>
        </div>
    </div>

    <!-- Info Section -->
    <div id="features" class="container py-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold">Tại sao chọn STEP?</h2>
            <p class="text-muted">Hệ sinh thái y tế thông minh kết nối Bệnh nhân - Thiết bị - Bác sĩ, mang lại hiệu quả phục hồi toàn diện.</p>
        </div>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-4 h-100 shadow-sm border border-light">
                    <div class="feature-icon bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width:70px;height:70px;">
                        <i class="bi bi-cpu fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Thiết bị Cảm biến Chuyên dụng</h5>
                    <p class="text-muted mb-0">Cảm biến ESP32S3 kết hợp MPU6050 đo góc gập duỗi khớp (ROM) chuẩn xác đến từng độ. Tự động đồng bộ lên nền tảng đám mây.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-4 h-100 shadow-sm border border-light">
                    <div class="feature-icon bg-success bg-opacity-10 text-success rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width:70px;height:70px;">
                        <i class="bi bi-graph-up fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Biểu đồ Thời gian thực (Live)</h5>
                    <p class="text-muted mb-0">Ứng dụng SignalR truyền tải dữ liệu trực tiếp với độ trễ mili-giây, giúp bác sĩ và bệnh nhân nhìn thấy ngay phản hồi khi vận động.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-4 h-100 shadow-sm border border-light">
                    <div class="feature-icon bg-info bg-opacity-10 text-info rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width:70px;height:70px;">
                        <i class="bi bi-hospital fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Giám sát Y khoa 24/7</h5>
                    <p class="text-muted mb-0">Thuật toán Round-Robin thông minh tự động chỉ định bác sĩ. Phác đồ điều trị được cá nhân hóa liên tục dựa trên tiến triển thực tế của bệnh nhân.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-4 h-100 shadow-sm border border-light">
                    <div class="feature-icon bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width:70px;height:70px;">
                        <i class="bi bi-shield-lock fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Bảo mật Y tế An toàn</h5>
                    <p class="text-muted mb-0">Hệ thống phân quyền chi tiết (Admin, Doctor, Patient). Toàn bộ dữ liệu bệnh án được mã hóa và bảo vệ quyền riêng tư tuyệt đối.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-4 h-100 shadow-sm border border-light">
                    <div class="feature-icon bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width:70px;height:70px;">
                        <i class="bi bi-wallet2 fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Thương mại Điện tử Tích hợp</h5>
                    <p class="text-muted mb-0">Mua sắm thiết bị y tế chính hãng trực tiếp qua hệ thống với quy trình giỏ hàng, checkout nhanh chóng tiện lợi.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-4 h-100 shadow-sm border border-light">
                    <div class="feature-icon bg-secondary bg-opacity-10 text-secondary rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width:70px;height:70px;">
                        <i class="bi bi-phone fs-2"></i>
                    </div>
                    <h5 class="fw-bold">Tương thích Đa nền tảng</h5>
                    <p class="text-muted mb-0">Sử dụng mượt mà trên Mobile, Tablet và Desktop (Web App) giúp người dùng dễ dàng theo dõi sức khỏe ở bất kỳ đâu.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Details Section -->
    <div id="product-details" class="bg-white py-5 border-bottom">
        <div class="container py-4">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <div class="position-relative">
                        <img src="https://placehold.co/600x450/e0e7ff/4f46e5?text=Smart+Band+STEP" alt="Thiết bị STEP" class="img-fluid rounded-4 shadow-lg w-100 object-fit-cover" />
                        <div class="position-absolute bottom-0 end-0 m-4 bg-white p-3 rounded-4 shadow-lg text-center">
                            <i class="bi bi-shield-check text-success fs-1"></i>
                            <div class="fw-bold mt-1">Đạt chuẩn Y tế</div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6">
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3">
                        <i class="bi bi-stars me-1"></i> Câu chuyện đằng sau sản phẩm
                    </span>
                    <h2 class="fw-bold mb-4">Từ Phòng Bệnh đến Cuộc Sống Bình Thường</h2>
                    <p class="text-muted mb-4 fs-5">Hệ thống <strong>STEP</strong> ra đời từ trăn trở của những người thân yêu phải đối mặt với hành trình phục hồi đơn độc. Chúng tôi tạo ra một người bạn đồng hành thông minh — luôn hiện diện, luôn đo lường, và luôn kết nối bạn với bác sĩ dù ở bất kỳ đâu.</p>
                    
                    <div class="d-flex mb-4 p-3 bg-light rounded-4 shadow-sm border border-white">
                        <div class="flex-shrink-0">
                            <div class="bg-primary bg-gradient text-white rounded-circle d-inline-flex justify-content-center align-items-center shadow" style="width:60px;height:60px;">
                                <i class="bi bi-cpu fs-3"></i>
                            </div>
                        </div>
                        <div class="ms-3">
                            <h5 class="fw-bold mb-1">Vòng đeo tay thông minh (Smart Band)</h5>
                            <p class="text-muted mb-0 small">Tích hợp vi điều khiển ESP32S3 và cảm biến góc MPU6050 có độ chính xác cao. Theo dõi từng cử động gập duỗi và xoay khớp cổ tay theo thời gian thực.</p>
                        </div>
                    </div>
                    
                    <div class="d-flex mb-4 p-3 bg-light rounded-4 shadow-sm border border-white">
                        <div class="flex-shrink-0">
                            <div class="bg-success bg-gradient text-white rounded-circle d-inline-flex justify-content-center align-items-center shadow" style="width:60px;height:60px;">
                                <i class="bi bi-cloud-arrow-up fs-3"></i>
                            </div>
                        </div>
                        <div class="ms-3">
                            <h5 class="fw-bold mb-1">Theo dõi tiến trình từ xa (Remote Monitoring)</h5>
                            <p class="text-muted mb-0 small">Hệ thống tự động ghi nhận và lưu trữ lịch sử luyện tập, giúp bác sĩ dễ dàng giám sát sự tiến bộ và điều chỉnh phác đồ phù hợp từ xa.</p>
                        </div>
                    </div>
                    
                    <div class="d-flex p-3 bg-light rounded-4 shadow-sm border border-white">
                        <div class="flex-shrink-0">
                            <div class="bg-info bg-gradient text-white rounded-circle d-inline-flex justify-content-center align-items-center shadow" style="width:60px;height:60px;">
                                <i class="bi bi-trophy fs-3"></i>
                            </div>
                        </div>
                        <div class="ms-3">
                            <h5 class="fw-bold mb-1">Hệ thống Tích điểm &amp; Thứ hạng</h5>
                            <p class="text-muted mb-0 small">Tập luyện đều đặn để tích điểm thưởng, thăng hạng thành viên (Đồng, Bạc, Vàng) và duy trì chuỗi tập (Streak) để đổi các voucher phụ kiện và ưu đãi giảm tần suất quảng cáo.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Target Audience (Đối tượng sử dụng) -->
    <div class="py-5 bg-light border-bottom">
        <div class="container py-4">
            <div class="text-center mb-5">
                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-2">
                    <i class="bi bi-people me-1"></i> Đối tượng sử dụng
                </span>
                <h2 class="fw-bold">STEP dành cho ai?</h2>
                <p class="text-muted">Giải pháp được thiết kế tối ưu cho nhiều nhóm đối tượng cần hỗ trợ phục hồi chức năng.</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <i class="bi bi-bandaid fs-2"></i>
                        </div>
                        <h5 class="fw-bold">Sau Chấn thương / Phẫu thuật</h5>
                        <p class="text-muted small">Người bị gãy xương, đứt gân, thoái hóa khớp sau khi tháo bột/phẫu thuật cần hệ thống giám sát để hạn chế sai tư thế và giúp bệnh nhân bắt kịp lộ trình phục hồi của bác sĩ.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <i class="bi bi-person-wheelchair fs-2"></i>
                        </div>
                        <h5 class="fw-bold">Người cao tuổi</h5>
                        <p class="text-muted small">Giúp người già duy trì sự linh hoạt của khớp, chống teo cơ, cứng khớp do ít vận động. Giao diện trực quan, dễ sử dụng chỉ với 1 nút bấm.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4">
                        <div class="bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                            <i class="bi bi-clipboard2-pulse fs-2"></i>
                        </div>
                        <h5 class="fw-bold">Phòng khám & Bệnh viện</h5>
                        <p class="text-muted small">Cung cấp công cụ mạnh mẽ cho Bác sĩ để theo dõi đồng thời hàng trăm bệnh nhân từ xa, tối ưu hóa nguồn lực y tế và giường bệnh.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tech Specs (Thông số Kỹ thuật) -->
    <div class="py-5 bg-white border-bottom">
        <div class="container py-4">
            <div class="row justify-content-center text-center mb-4">
                <div class="col-lg-8">
                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-3">
                        <i class="bi bi-motherboard me-1"></i> Sức mạnh Phần cứng
                    </span>
                    <h2 class="fw-bold mb-4">Lõi Công Nghệ Vi Điều Khiển ESP32S3</h2>
                    <p class="text-muted mb-4 fs-6">Sản phẩm Smart Band không phải là đồ chơi. Nó là một thiết bị hỗ trợ đo lường y sinh học thực thụ, được cấu thành từ những vi mạch tiên tiến nhất.</p>
                </div>
            </div>
            
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-4">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Cảm biến Gia tốc & Góc quay MPU6050 (6-DOF)</h6>
                                    <p class="text-muted small mb-0">Đo lường chính xác tọa độ 3D của bàn tay. Áp dụng bộ lọc Kalman filter để loại bỏ nhiễu rung lắc, tính toán ra góc gập (ROM - Range of Motion) với sai số dưới 1 độ.</p>
                                </div>
                            </div>
                        </li>
                        <li class="mb-4">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Kết nối Đa tầng WiFi + Bluetooth Low Energy (BLE)</h6>
                                    <p class="text-muted small mb-0">Chip ESP32S3 mạnh mẽ tự động chuyển đổi giữa WiFi để đẩy dữ liệu lên Cloud MQTT và BLE để ghép nối trực tiếp với Điện thoại siêu tiết kiệm pin.</p>
                                </div>
                            </div>
                        </li>
                        <li>
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3 mt-1"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Thời lượng Pin Lithium-Polymer 3000mAh</h6>
                                    <p class="text-muted small mb-0">Cho phép tập luyện liên tục 48 giờ hoặc chế độ Standby lên đến 2 tuần. Tích hợp cổng sạc Type-C siêu tốc.</p>
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>


    <!-- Motivation System Showcase (Xếp hạng & Tích điểm) -->
    <div class="py-5 bg-white border-bottom">
        <div class="container py-4">
            <div class="text-center mb-5">
                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 mb-2">
                    <i class="bi bi-trophy-fill me-1"></i> Động lực Tập luyện
                </span>
                <h2 class="fw-bold">Hệ Thống Tích Điểm &amp; Thăng Hạng Thành Viên</h2>
                <p class="text-muted">Đẩy lùi sự nhàm chán bằng cơ chế Streak liên tục, thăng hạng đồng hành cùng nhiều ưu đãi hấp dẫn.</p>
            </div>
            
            <div class="row g-4">
                <!-- Rank 1 -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden hover-lift">
                        <div class="card-body p-4 text-center">
                            <div class="bg-warning bg-opacity-15 text-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                                <i class="bi bi-award fs-1"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Phân hạng Thành viên (Đồng, Bạc, Vàng)</h5>
                            <p class="text-muted small mb-0">Hoàn thành các mục tiêu tập luyện cổ tay để nâng dần cấp độ từ Đồng lên Bạc, Vàng và Kim Cương. Mỗi mức hạng phản ánh chính xác sự cải thiện tầm vận động (ROM) của bạn.</p>
                        </div>
                    </div>
                </div>
                <!-- Rank 2 -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden hover-lift">
                        <div class="card-body p-4 text-center">
                            <div class="bg-danger bg-opacity-10 text-danger rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                                <i class="bi bi-fire fs-1"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Duy trì Chuỗi Streak &amp; Nhân Điểm</h5>
                            <p class="text-muted small mb-0">Tập luyện đều đặn mỗi ngày để duy trì chuỗi ngày tập liên tiếp. Chuỗi Streak càng dài giúp nhân hệ số điểm thưởng tích lũy, kích thích tinh thần tập luyện kỷ luật tại nhà.</p>
                        </div>
                    </div>
                </div>
                <!-- Rank 3 -->
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm rounded-4 h-100 overflow-hidden hover-lift">
                        <div class="card-body p-4 text-center">
                            <div class="bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 70px; height: 70px;">
                                <i class="bi bi-ticket-perforated fs-1"></i>
                            </div>
                            <h5 class="fw-bold mb-2">Đặc quyền Hạng Cao (Ads &amp; Vouchers)</h5>
                            <p class="text-muted small mb-0">Bệnh nhân thăng hạng càng cao sẽ càng nhận được ít quảng cáo hiển thị trên ứng dụng (Đặc quyền miễn quảng cáo hoàn toàn từ hạng Vàng). Đồng thời nhận các Voucher giảm giá phụ kiện y tế STEP hàng tháng.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-center mt-5">
