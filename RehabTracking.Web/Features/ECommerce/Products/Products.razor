@if (showDetailsModal && selectedProduct != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5); z-index: 1050;" @onclick="CloseDetailsModal">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content rounded-4 border-0 shadow-lg overflow-hidden">
                <div class="modal-header border-0 pb-0 position-absolute top-0 end-0 z-1">
                    <button type="button" class="btn-close bg-white rounded-circle p-2 m-2 shadow-sm" @onclick="CloseDetailsModal"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="row g-0">
                        <div class="col-md-5 bg-light d-flex align-items-center justify-content-center p-4">
                            <div class="position-relative w-100">
                                <img src="@(string.IsNullOrEmpty(selectedProduct.ImageUrl) ? "https://placehold.co/400x400/e0e7ff/6366f1?text=No+Image" : selectedProduct.ImageUrl)" 
                                     alt="@selectedProduct.ProductName" 
                                     class="img-fluid rounded-3 shadow-sm w-100 object-fit-cover" style="max-height:350px;"/>
                                @if (selectedProduct.StockQuantity <= 0)
                                {
                                    <div class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-75 d-flex justify-content-center align-items-center rounded-3">
                                        <span class="badge bg-danger fs-5 px-3 py-2 rounded-pill shadow">Hết hàng</span>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-md-7 d-flex flex-column p-4 p-md-5">
                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill align-self-start mb-3 px-3 py-2">
                                <i class="bi bi-tag-fill me-1"></i> @selectedProduct.ProductType
                            </span>
                            
                            <h3 class="fw-bold mb-2">@selectedProduct.ProductName</h3>
                            <h3 class="text-primary fw-bold mb-4">@selectedProduct.Price.ToString("N0")₫</h3>
                            
                            <div class="mb-4 flex-grow-1">
                                <h6 class="fw-bold text-dark mb-2">Thông tin sản phẩm</h6>
                                <p class="text-muted" style="white-space: pre-line; line-height: 1.6;">@(string.IsNullOrEmpty(selectedProduct.Description) ? "Đang cập nhật mô tả chi tiết..." : selectedProduct.Description)</p>
                            </div>
                            
                            <div class="d-flex align-items-center mb-4 p-3 bg-light rounded-3">
                                <i class="bi bi-box-seam fs-4 text-muted me-3"></i>
                                <div>
                                    <div class="text-muted small mb-1">Tình trạng kho hàng</div>
                                    @if (selectedProduct.StockQuantity > 0)
                                    {
                                        <div class="text-success fw-bold">Còn @selectedProduct.StockQuantity sản phẩm sẵn sàng giao</div>
                                    }
                                    else
                                    {
                                        <div class="text-danger fw-bold">Tạm thời hết hàng</div>
                                    }
                                </div>
                            </div>
                            
                            <button class="btn btn-modern-primary btn-lg rounded-pill w-100 shadow-sm fw-bold py-3"
                                    disabled="@(selectedProduct.StockQuantity <= 0)"
                                    @onclick="async () => { await AddToCart(selectedProduct); CloseDetailsModal(); }">
                                <i class="bi bi-cart-plus fs-5 me-2"></i>
                                @(selectedProduct.StockQuantity > 0 ? "Thêm vào giỏ hàng ngay" : "Không thể đặt hàng")
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    html {
        scroll-behavior: smooth;
    }

    .hero-section {
        background: linear-gradient(135deg, #4f46e5 0%, #0ea5e9 50%, #ec4899 100%);
        min-height: 60vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }

    .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        border-radius: 9999px;
        padding: 0.4rem 1.2rem;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .feature-card {
        background: white;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1) !important;
    }

    .product-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .product-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px rgba(79,70,229,0.15) !important;
    }

    .out-of-stock-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.5);
    }

    .skeleton-box {
        background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
        background-size: 200% 100%;
        animation: shimmer 1.5s infinite;
        border-radius: 0.5rem;
    }

    @@keyframes shimmer {
        0% { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* Animation classes */
    .animate-fade-in-up {
        animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @@keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .fw-black {
        font-weight: 900;
    }
</style>

@code {
    private List<Product>? products;
    private bool isLoading = true;
    private string addedMessage = string.Empty;
    
    private bool showDetailsModal = false;
    private Product? selectedProduct;
    
    // For FAQ Accordion
    private string activeFaq = string.Empty;

    private void ToggleFaq(string id)
    {
        activeFaq = activeFaq == id ? string.Empty : id;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            products = await Mediator.Send(new GetProductsQuery());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching products: {ex.Message}");
            products = new List<Product>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddToCart(Product product)
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity == null || !authState.User.Identity.IsAuthenticated)
        {
            Navigation.NavigateTo("/login?returnUrl=/");
            return;
        }

        if (product.StockQuantity <= 0) return;

        // Đảm bảo CartState biết user hiện tại trước khi thêm hàng
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier);
        if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
        {
            CartState.SetUser(userId);
        }

        CartState.AddToCart(product, 1);
        // Show toast notification instead of redirecting immediately
        addedMessage = product.ProductName;
        _ = AutoDismissToast();
    }

    private async Task AutoDismissToast()
    {
        await Task.Delay(5000);
        addedMessage = string.Empty;
        await InvokeAsync(StateHasChanged);
    }

    private void ShowDetailsModal(Product product)
    {
        selectedProduct = product;
        showDetailsModal = true;
    }

    private void CloseDetailsModal()
    {
        showDetailsModal = false;
        selectedProduct = null;
    }

}
