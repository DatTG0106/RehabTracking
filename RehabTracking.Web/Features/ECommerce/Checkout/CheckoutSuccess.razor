@page "/checkout/success"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Đặt hàng thành công - RehabTracking</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <!-- Success animation -->
                <div class="success-icon-wrapper mb-4">
                    <div class="success-ring">
                        <i class="bi bi-check-lg text-white"></i>
                    </div>
                </div>

                <h2 class="fw-bold text-dark mb-2">Đặt hàng thành công!</h2>
                <p class="text-muted lead mb-4">Cảm ơn bạn đã mua hàng. Đơn hàng của bạn đang được xử lý và sẽ sớm được giao.</p>

                <div class="bg-light rounded-3 p-3 mb-4 text-start">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <i class="bi bi-truck text-primary fs-4"></i>
                        <div>
                            <div class="fw-semibold">Đơn hàng đang được chuẩn bị</div>
                            <div class="text-muted small">Admin sẽ gán thiết bị IoT và giao trong 3-5 ngày</div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-watch text-success fs-4"></i>
                        <div>
                            <div class="fw-semibold">Kích hoạt thiết bị</div>
                            <div class="text-muted small">Dùng mã serial trên hộp để kích hoạt tại mục "Activate Device"</div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-modern-primary rounded-pill btn-lg fw-semibold shadow-sm" @onclick='() => Navigation.NavigateTo("/")'>
                        <i class="bi bi-house me-2"></i>Về trang chủ
                    </button>
                    <button class="btn btn-outline-primary rounded-pill" @onclick='() => Navigation.NavigateTo("/activate-device")'>
                        <i class="bi bi-watch me-2"></i>Kích hoạt thiết bị ngay
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .success-icon-wrapper {
        display: flex;
        justify-content: center;
    }
    .success-ring {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #10b981, #059669);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        animation: successPop 0.5s ease-out;
        box-shadow: 0 0 0 16px rgba(16,185,129,0.15), 0 0 0 32px rgba(16,185,129,0.07);
    }
    @@keyframes successPop {
        0% { transform: scale(0); }
        70% { transform: scale(1.15); }
        100% { transform: scale(1); }
    }
</style>
