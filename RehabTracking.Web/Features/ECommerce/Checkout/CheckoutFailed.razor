@page "/checkout/failed"
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Thanh toán thất bại - RehabTracking</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <!-- Failed icon -->
                <div class="failed-icon-wrapper mb-4">
                    <div class="failed-ring">
                        <i class="bi bi-x-lg text-white"></i>
                    </div>
                </div>

                <h2 class="fw-bold text-dark mb-2">Thanh toán thất bại</h2>
                <p class="text-muted lead mb-4">Rất tiếc, giao dịch của bạn đã bị hủy hoặc xảy ra lỗi. Đơn hàng của bạn vẫn còn trong hệ thống.</p>

                <div class="alert alert-warning border-0 rounded-3 text-start mb-4" role="alert">
                    <div class="d-flex gap-2 align-items-start">
                        <i class="bi bi-lightbulb-fill flex-shrink-0 mt-1"></i>
                        <div class="small">
                            <div class="fw-semibold mb-1">Bạn có thể:</div>
                            <ul class="mb-0 ps-3">
                                <li>Thử lại thanh toán VNPay</li>
                                <li>Chọn phương thức COD (tiền mặt)</li>
                                <li>Liên hệ hỗ trợ nếu vấn đề tiếp diễn</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg rounded-pill fw-semibold shadow-sm" @onclick='() => Navigation.NavigateTo("/")'>
                        <i class="bi bi-arrow-repeat me-2"></i>Mua lại từ đầu
                    </button>
                    <button class="btn btn-outline-secondary rounded-pill" @onclick='() => Navigation.NavigateTo("/")'>
                        <i class="bi bi-house me-2"></i>Về trang chủ
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .failed-icon-wrapper {
        display: flex;
        justify-content: center;
    }
    .failed-ring {
        width: 100px;
        height: 100px;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        animation: failedPop 0.5s ease-out;
        box-shadow: 0 0 0 16px rgba(239,68,68,0.15), 0 0 0 32px rgba(239,68,68,0.07);
    }
    @@keyframes failedPop {
        0% { transform: scale(0); }
        70% { transform: scale(1.15); }
        100% { transform: scale(1); }
    }
</style>
