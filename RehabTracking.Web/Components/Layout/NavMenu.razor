@using RehabTracking.Web.Features.ECommerce.Cart
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject CartState CartState
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@implements IDisposable
@rendermode InteractiveServer

<nav class="navbar navbar-expand-lg glass-navbar px-3 py-2">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/">
            <i class="bi bi-activity text-primary fs-3"></i>
            <span>STEP</span>
        </a>

        <!-- Mobile toggle -->
        <button class="navbar-toggler border-0 shadow-none" type="button" @onclick="ToggleMobileMenu" aria-label="Toggle navigation">
            <i class="bi @(mobileMenuOpen ? "bi-x-lg" : "bi-list") fs-4"></i>
        </button>

        <div class="@(mobileMenuOpen ? "d-block" : "collapse") navbar-collapse" id="navbarContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item" @onclick="CloseMobileMenu">
                    <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                        <i class="bi bi-shop me-1"></i> Sản phẩm
                    </NavLink>
                </li>

                <AuthorizeView Roles="Patient">
                    <li class="nav-item ms-lg-2" @onclick="CloseMobileMenu">
                        <NavLink class="nav-link" href="patient-dashboard">
                            <i class="bi bi-person-heart me-1"></i> Dashboard Bệnh nhân
                        </NavLink>
                    </li>
                    <li class="nav-item ms-lg-2" @onclick="CloseMobileMenu">
                        <NavLink class="nav-link" href="activate-device">
                            <i class="bi bi-watch me-1"></i> Kích hoạt thiết bị
                        </NavLink>
                    </li>
                </AuthorizeView>

                <AuthorizeView Roles="Doctor">
                    <li class="nav-item ms-lg-2" @onclick="CloseMobileMenu">
                        <NavLink class="nav-link" href="doctor-dashboard">
                            <i class="bi bi-heart-pulse me-1"></i> Dashboard Bác sĩ
                        </NavLink>
                    </li>
                </AuthorizeView>

                <AuthorizeView Roles="Admin">
                    <li class="nav-item ms-lg-2" @onclick="CloseMobileMenu">
                        <NavLink class="nav-link" href="admin-dashboard">
                            <i class="bi bi-speedometer2 me-1"></i> Quản lý Đơn hàng
                        </NavLink>
                    </li>
                </AuthorizeView>
            </ul>

            <ul class="navbar-nav align-items-lg-center gap-1">
                <!-- Cart Icon with count badge -->
                <li class="nav-item">
                    <NavLink class="nav-link position-relative px-2" href="cart" aria-label="Giỏ hàng">
                        <i class="bi bi-cart3 fs-5"></i>
                        @if (cartCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                  style="font-size:0.65rem; padding: 0.3em 0.5em; min-width:18px;">
                                @(cartCount > 99 ? "99+" : cartCount.ToString())
                            </span>
                        }
                    </NavLink>
                </li>

                <AuthorizeView>
                    <Authorized>
                        <!-- Blazor-native dropdown (not Bootstrap JS) -->
                        <li class="nav-item position-relative">
                            <button class="btn nav-link d-flex align-items-center gap-2 px-2 py-1 border-0 bg-transparent"
                                    @onclick="ToggleUserDropdown"
                                    @onclick:stopPropagation="true">
                                <div class="user-avatar bg-primary text-white rounded-circle d-flex justify-content-center align-items-center fw-bold"
                                     style="width:34px;height:34px;font-size:0.9rem;flex-shrink:0;">
                                    @GetInitial(context.User.Identity?.Name)
                                </div>
                                <span class="d-none d-lg-inline fw-medium" style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @context.User.Identity?.Name
                                </span>
                                <i class="bi bi-chevron-down small @(userDropdownOpen ? "rotate-180" : "")" style="transition:transform 0.2s;"></i>
                            </button>

                            <!-- Blazor dropdown menu -->
                            @if (userDropdownOpen)
                            {
                                <!-- Overlay to close on outside click -->
                                <div class="dropdown-overlay" @onclick="CloseUserDropdown"></div>

                                <div class="blazor-dropdown-menu shadow-lg" @onclick:stopPropagation="true">
                                    <!-- User info header -->
                                    <div class="px-3 py-3 border-bottom">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="user-avatar bg-primary text-white rounded-circle d-flex justify-content-center align-items-center fw-bold"
                                                 style="width:40px;height:40px;font-size:1rem;flex-shrink:0;">
                                                @GetInitial(context.User.Identity?.Name)
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark" style="font-size:0.9rem;">@context.User.Identity?.Name</div>
                                                <div class="text-muted" style="font-size:0.78rem;">
                                                    @context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                                                </div>
                                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill mt-1" style="font-size:0.7rem;">
                                                    @context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                                                </span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Role-specific menu items -->
                                    <AuthorizeView Roles="Patient" Context="patCtx">
                                        <div class="px-2 py-1">
                                            <button class="dropdown-item-btn w-100 text-start" @onclick='() => GoTo("/patient-dashboard")'>
                                                <i class="bi bi-person-heart text-success me-2"></i> Dashboard của tôi
                                            </button>
                                            <button class="dropdown-item-btn w-100 text-start" @onclick='() => GoTo("/activate-device")'>
                                                <i class="bi bi-watch text-primary me-2"></i> Kích hoạt thiết bị
                                            </button>
                                        </div>
                                        <hr class="my-1 mx-2" />
                                    </AuthorizeView>

                                    <AuthorizeView Roles="Doctor" Context="docCtx">
                                        <div class="px-2 py-1">
                                            <button class="dropdown-item-btn w-100 text-start" @onclick='() => GoTo("/doctor-dashboard")'>
                                                <i class="bi bi-heart-pulse text-danger me-2"></i> Dashboard Bác sĩ
                                            </button>
                                        </div>
                                        <hr class="my-1 mx-2" />
                                    </AuthorizeView>

                                    <AuthorizeView Roles="Admin" Context="admCtx">
                                        <div class="px-2 py-1">
                                            <button class="dropdown-item-btn w-100 text-start" @onclick='() => GoTo("/admin-dashboard")'>
                                                <i class="bi bi-speedometer2 text-warning me-2"></i> Quản lý Đơn hàng
                                            </button>
                                        </div>
                                        <hr class="my-1 mx-2" />
                                    </AuthorizeView>

                                    <div class="px-2 py-1 pb-2">
                                        <button class="dropdown-item-btn w-100 text-start text-danger" @onclick="HandleLogout">
                                            <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                                        </button>
                                    </div>
                                </div>
                            }
                        </li>
                    </Authorized>
                    <NotAuthorized>
                        <li class="nav-item ms-2">
                            <NavLink class="btn btn-modern btn-modern-primary px-4 shadow-sm" href="login">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Đăng nhập
                            </NavLink>
                        </li>
                    </NotAuthorized>
                </AuthorizeView>
            </ul>
        </div>
    </div>
</nav>

<style>
    .rotate-180 {
        transform: rotate(180deg);
    }

    .user-avatar {
        flex-shrink: 0;
        cursor: pointer;
    }

    /* Blazor-native dropdown panel */
    .blazor-dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        min-width: 230px;
        background: white;
        border-radius: 0.875rem;
        border: 1px solid rgba(0,0,0,0.06);
        box-shadow: 0 10px 40px rgba(0,0,0,0.12), 0 4px 16px rgba(0,0,0,0.06);
        z-index: 1050;
        animation: dropdownFadeIn 0.18s ease-out;
        overflow: hidden;
    }

    @@keyframes dropdownFadeIn {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Overlay to detect outside click */
    .dropdown-overlay {
        position: fixed;
        inset: 0;
        z-index: 1040;
        background: transparent;
    }

    /* Dropdown item buttons */
    .dropdown-item-btn {
        display: flex;
        align-items: center;
        padding: 0.55rem 0.75rem;
        border: none;
        background: transparent;
        border-radius: 0.5rem;
        font-weight: 500;
        font-size: 0.9rem;
        color: #0f172a;
        cursor: pointer;
        transition: background-color 0.15s ease, color 0.15s ease;
        font-family: 'Inter', sans-serif;
    }

    .dropdown-item-btn:hover {
        background-color: rgba(79, 70, 229, 0.07);
        color: var(--primary-color, #4f46e5);
    }

    .dropdown-item-btn.text-danger:hover {
        background-color: rgba(239, 68, 68, 0.07);
        color: #dc2626 !important;
    }

    /* Mobile nav improvements */
    @@media (max-width: 991.98px) {
        .blazor-dropdown-menu {
            position: fixed;
            top: auto;
            right: 1rem;
            bottom: auto;
        }
        .navbar-collapse.d-block {
            border-top: 1px solid rgba(0,0,0,0.06);
            padding-top: 0.5rem;
            padding-bottom: 0.5rem;
            margin-top: 0.5rem;
            background: rgba(255,255,255,0.98);
            border-radius: 0 0 1rem 1rem;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }
    }
</style>

@code {
    private int cartCount = 0;
    private bool userDropdownOpen = false;
    private bool mobileMenuOpen = false;
    private int _currentUserId = 0;

    protected override async Task OnInitializedAsync()
    {
        // Gán UserId vào CartState để isolate giỏ hàng theo user
        await SyncUserToCart();

        CartState.OnChange += HandleCartChange;
        AuthenticationStateProvider.AuthenticationStateChanged += OnAuthStateChanged;

        cartCount = CartState.Items.Sum(i => i.Quantity);
    }

    /// <summary>
    /// Đọc UserId từ claims và gán vào CartState.
    /// Được gọi khi init và khi auth state thay đổi (login/logout).
    /// </summary>
    private async Task SyncUserToCart()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
            {
                _currentUserId = userId;
                CartState.SetUser(userId);
            }
        }
        else
        {
            // User đã đăng xuất: reset về 0, giỏ hàng sẽ trả về rỗng
            _currentUserId = 0;
            CartState.SetUser(0);
        }
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        await SyncUserToCart();
        cartCount = CartState.Items.Sum(i => i.Quantity);
        await InvokeAsync(StateHasChanged);
    }

    private void HandleCartChange()
    {
        cartCount = CartState.Items.Sum(i => i.Quantity);
        InvokeAsync(StateHasChanged);
    }

    private void ToggleUserDropdown()
    {
        userDropdownOpen = !userDropdownOpen;
    }

    private void CloseUserDropdown()
    {
        userDropdownOpen = false;
    }

    private void ToggleMobileMenu()
    {
        mobileMenuOpen = !mobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        mobileMenuOpen = false;
        userDropdownOpen = false;
    }

    private void GoTo(string url)
    {
        userDropdownOpen = false;
        mobileMenuOpen = false;
        Navigation.NavigateTo(url);
    }

    private void HandleLogout()
    {
        userDropdownOpen = false;
        // Xóa giỏ hàng của user hiện tại trước khi đăng xuất
        if (_currentUserId > 0)
        {
            CartState.ClearCartForUser(_currentUserId);
        }
        // Navigate to logout endpoint - force full page load to bypass Blazor router
        Navigation.NavigateTo("/api/auth/logout", forceLoad: true);
    }

    private static string GetInitial(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        return name.Trim().Substring(0, 1).ToUpper();
    }

    public void Dispose()
    {
        CartState.OnChange -= HandleCartChange;
        AuthenticationStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
